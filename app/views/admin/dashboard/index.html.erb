<h2>Admin Dashboard</h2>

<div class="admin-stats-grid">
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @total_drivers %></div>
    <div class="admin-stat-label">Total Drivers</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @active_drivers %></div>
    <div class="admin-stat-label">Active Drivers</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @total_races %></div>
    <div class="admin-stat-label">Total Races</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @total_seasons %></div>
    <div class="admin-stat-label">Seasons</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @elo_version.upcase %></div>
    <div class="admin-stat-label">Elo Version</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @v2_populated ? "Yes" : "No" %></div>
    <div class="admin-stat-label">V2 Data</div>
  </div>
</div>

<% if @alerts.any? %>
<div class="admin-alerts-section">
  <h3><i class="fa-solid fa-triangle-exclamation"></i> Alerts (<%= @alerts.size %>)</h3>
  <% @alerts.each do |alert| %>
    <div class="admin-alert admin-alert-<%= alert.severity %>">
      <div class="admin-alert-header">
        <strong><%= alert.title %></strong>
        <span class="admin-alert-meta"><%= alert.source %> &middot; <%= time_ago_in_words(alert.created_at) %> ago</span>
      </div>
      <% if alert.message.present? %>
        <pre class="admin-alert-message"><%= truncate(alert.message, length: 300) %></pre>
      <% end %>
      <%= button_to "Resolve", admin_alert_path(alert), method: :patch, class: "admin-btn admin-btn-sm" %>
    </div>
  <% end %>
</div>
<% end %>

<div class="admin-cards-row">
  <div class="admin-card">
    <h3><i class="fa-solid fa-sliders"></i> Settings</h3>
    <p>Toggle Elo version, view V2 parameters.</p>
    <%= link_to "Go to Settings", admin_settings_path, class: "admin-btn" %>
  </div>
  <div class="admin-card">
    <h3><i class="fa-solid fa-gears"></i> Operations</h3>
    <p>Sync data, re-simulate Elo, backfill stats.</p>
    <%= link_to "Go to Operations", admin_operations_path, class: "admin-btn" %>
  </div>
  <div class="admin-card">
    <h3><i class="fa-solid fa-database"></i> Blazer</h3>
    <p>Run SQL queries against the database.</p>
    <%= link_to "Open Blazer", blazer_path, class: "admin-btn" %>
  </div>
</div>

<h3 style="margin-top: 32px;"><i class="fa-solid fa-chart-bar"></i> Analytics</h3>
<div class="admin-stats-grid">
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @users_count %></div>
    <div class="admin-stat-label">Users</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @visits_today %></div>
    <div class="admin-stat-label">Visits Today</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @visits_7d %></div>
    <div class="admin-stat-label">Visits (7d)</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @visits_30d %></div>
    <div class="admin-stat-label">Visits (30d)</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @pageviews_today %></div>
    <div class="admin-stat-label">Page Views Today</div>
  </div>
</div>

<% if @top_pages.any? %>
  <h4 style="margin-top: 24px;">Top Pages (7d)</h4>
  <div class="card card-flush" style="margin-top: 8px;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Page</th>
          <th class="text-center">Views</th>
        </tr>
      </thead>
      <tbody>
        <% @top_pages.each do |(controller, action), count| %>
          <tr>
            <td><%= controller %>#<%= action %></td>
            <td class="text-center"><%= number_with_delimiter(count) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
