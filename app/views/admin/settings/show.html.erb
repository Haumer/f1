<h2>Settings</h2>

<div class="admin-card">
  <h3>Elo Version</h3>
  <p>The system uses Elo V2 with K-factor scaling, grid normalization, and season regression.</p>
</div>

<div class="admin-card">
  <h3>Date Override</h3>
  <p>Simulate a different date for the homepage contextual logic (race day, pre-race, post-race). Leave blank for real date.</p>

  <%= form_with url: admin_settings_path, method: :patch, class: "admin-form" do |f| %>
    <div style="display: flex; gap: 12px; align-items: center;">
      <input type="date" name="simulated_date" value="<%= @simulated_date %>" class="admin-input">
      <button type="submit" class="admin-btn">Set Date</button>
    </div>
  <% end %>

  <% if @simulated_date.present? %>
    <div style="margin-top: 12px;">
      <span class="admin-radio-desc">Currently simulating: <strong><%= @simulated_date %></strong></span>
      <%= form_with url: admin_settings_path, method: :patch, style: "display: inline;" do %>
        <input type="hidden" name="clear_simulated_date" value="1">
        <button type="submit" class="admin-btn" style="background: #6c757d;">Clear Override</button>
      <% end %>
    </div>
  <% end %>

  <% if @race_dates.any? %>
    <details style="margin-top: 16px;">
      <summary style="cursor: pointer; font-size: 13px; color: #6c757d;">Race Calendar (click to expand)</summary>
      <table class="admin-params-table" style="margin-top: 8px;">
        <tbody>
          <% @race_dates.each do |r| %>
            <tr>
              <td class="param-label">R<%= r[:round] %></td>
              <td class="param-value"><%= r[:date].strftime("%b %d") %></td>
              <td class="param-desc"><%= r[:circuit] %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </details>
  <% end %>
</div>

<div class="admin-card">
  <h3>Badge Minimum Year</h3>
  <p>Only count races from this year onwards for badge calculations. Pre-<%= @badge_min_year %> races with irregular grid sizes are excluded.</p>

  <%= form_with url: admin_settings_path, method: :patch, class: "admin-form" do |f| %>
    <div style="display: flex; gap: 12px; align-items: center;">
      <input type="number" name="badge_min_year" value="<%= @badge_min_year %>" min="1950" max="2026" class="admin-input" style="width: 100px;">
      <button type="submit" class="admin-btn">Save</button>
    </div>
  <% end %>
</div>

<div class="admin-card">
  <h3>Fantasy Stock Market</h3>
  <p>Enable the stock market game mode where drivers are traded as stocks with dividends and short selling.</p>

  <%= form_with url: admin_settings_path, method: :patch, class: "admin-form" do |f| %>
    <div class="admin-radio-group">
      <label class="admin-radio <%= 'selected' unless @fantasy_stock_market %>">
        <input type="radio" name="fantasy_stock_market" value="disabled" <%= 'checked' unless @fantasy_stock_market %>>
        <div>
          <strong>Disabled</strong>
          <span class="admin-radio-desc">Stock market hidden from users</span>
        </div>
      </label>
      <label class="admin-radio <%= 'selected' if @fantasy_stock_market %>">
        <input type="radio" name="fantasy_stock_market" value="enabled" <%= 'checked' if @fantasy_stock_market %>>
        <div>
          <strong>Enabled</strong>
          <span class="admin-radio-desc">Users can create stock portfolios and trade driver shares</span>
        </div>
      </label>
    </div>
    <button type="submit" class="admin-btn">Save</button>
  <% end %>
</div>

<div class="admin-card">
  <h3>Accent Color Override</h3>
  <p>Override the homepage champion accent color with a specific constructor. Useful for pre-season when no champion data exists yet (e.g. McLaren for 2026).</p>

  <%= form_with url: admin_settings_path, method: :patch, class: "admin-form" do |f| %>
    <div style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <select name="accent_constructor_override" class="admin-input" style="width: 200px;">
        <option value="">Auto-detect (default)</option>
        <% Constructor::COLORS.each do |ref, color| %>
          <option value="<%= ref %>" <%= 'selected' if @accent_override == ref.to_s %> style="color: <%= color %>;">
            <%= ref.to_s.titleize %>
          </option>
        <% end %>
      </select>
      <button type="submit" class="admin-btn">Save</button>
    </div>
    <% if @accent_override.present? %>
      <div style="margin-top: 12px; display: flex; align-items: center; gap: 8px;">
        <span style="width: 16px; height: 16px; border-radius: 50%; background: <%= Constructor::COLORS[@accent_override.to_sym] %>; display: inline-block;"></span>
        <span class="admin-radio-desc">Currently overriding with: <strong><%= @accent_override.titleize %></strong></span>
      </div>
    <% end %>
  <% end %>
</div>

<div class="admin-card">
  <h3>Image Source</h3>
  <p>Switch between F1 CDN images (higher quality, hotlinked) and Wikipedia images (CC-licensed, fallback).</p>

  <%= form_with url: admin_settings_path, method: :patch, class: "admin-form" do |f| %>
    <div class="admin-radio-group">
      <label class="admin-radio <%= 'selected' if @image_source == 'f1' %>">
        <input type="radio" name="image_source" value="f1" <%= 'checked' if @image_source == 'f1' %>>
        <div>
          <strong>F1 CDN</strong>
          <span class="admin-radio-desc">Official headshots from media.formula1.com (current drivers only)</span>
        </div>
      </label>
      <label class="admin-radio <%= 'selected' if @image_source == 'wikipedia' %>">
        <input type="radio" name="image_source" value="wikipedia" <%= 'checked' if @image_source == 'wikipedia' %>>
        <div>
          <strong>Wikipedia</strong>
          <span class="admin-radio-desc">CC-licensed images from Wikipedia (broader coverage, lower quality)</span>
        </div>
      </label>
    </div>
    <button type="submit" class="admin-btn">Save</button>
  <% end %>
</div>

<div class="admin-card">
  <h3>V2 Parameters</h3>
  <table class="admin-params-table">
    <tbody>
      <tr>
        <td class="param-label">Base K-Factor</td>
        <td class="param-value"><%= EloRatingV2::BASE_K %></td>
        <td class="param-desc">Per-pair K before normalization</td>
      </tr>
      <tr>
        <td class="param-label">Starting Elo</td>
        <td class="param-value"><%= EloRatingV2::STARTING_ELO.to_i %></td>
        <td class="param-desc">Default rating for new drivers</td>
      </tr>
      <tr>
        <td class="param-label">Regression</td>
        <td class="param-value">None</td>
        <td class="param-desc">No seasonal regression — ratings are purely performance-based</td>
      </tr>
      <tr>
        <td class="param-label">Reference Races</td>
        <td class="param-value"><%= EloRatingV2::REFERENCE_RACES.to_i %></td>
        <td class="param-desc">Baseline season length for K scaling</td>
      </tr>
      <tr>
        <td class="param-label">Scale</td>
        <td class="param-value"><%= EloRatingV2::SCALE.to_i %></td>
        <td class="param-desc">Rating difference for 10:1 expected win ratio</td>
      </tr>
      <tr>
        <td class="param-label">Grid Normalization</td>
        <td class="param-value">sqrt(n-1)</td>
        <td class="param-desc">K divided by sqrt of opponents count</td>
      </tr>
    </tbody>
  </table>
</div>
