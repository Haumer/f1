<h2>Analytics</h2>

<div class="admin-period-tabs">
  <% %w[today 7d 30d all].each do |p| %>
    <%= link_to p.titleize, admin_analytics_path(period: p), class: "admin-btn admin-btn-sm #{'admin-btn-active' if @period == p}" %>
  <% end %>
  <% if @excluded_ids.any? %>
    <span class="admin-filter-badge"><i class="fa-solid fa-filter"></i> <%= @excluded_ids.size %> excluded</span>
  <% end %>
  <%= link_to "Blazer", blazer_path, class: "admin-btn admin-btn-sm", style: "margin-left: auto;" %>
</div>

<div class="admin-stats-grid">
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= number_with_delimiter(@unique_visitors) %></div>
    <div class="admin-stat-label">Unique Visitors</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= number_with_delimiter(@visits) %></div>
    <div class="admin-stat-label">Visits</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= number_with_delimiter(@pageviews) %></div>
    <div class="admin-stat-label">Page Views</div>
  </div>
  <div class="admin-stat-card">
    <div class="admin-stat-value"><%= @visits > 0 ? (@pageviews.to_f / @visits).round(1) : 0 %></div>
    <div class="admin-stat-label">Pages / Visit</div>
  </div>
</div>

<%# ═══ Excluded Users Panel ═══ %>
<div class="admin-card" style="margin-top: 32px;">
  <h3><i class="fa-solid fa-user-slash"></i> Filter Users from Analytics</h3>
  <p style="color: #888; font-size: 13px; margin-bottom: 16px;">Excluded users' visits and pageviews are stripped from all analytics counts and charts.</p>

  <div data-controller="expand" style="overflow: hidden;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>User</th>
          <th class="text-center">All-time Visits</th>
          <th class="text-center">Status</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @top_users_for_exclusion.first(5).each do |user| %>
          <% excluded = @excluded_ids.include?(user.id) %>
          <tr>
            <td><%= user.username || user.email %></td>
            <td class="text-center"><%= number_with_delimiter(user.total_visits) %></td>
            <td class="text-center">
              <% if excluded %>
                <span class="admin-badge" style="background: #6c757d;">Excluded</span>
              <% else %>
                <span class="admin-badge" style="background: rgba(31, 136, 61, 0.8);">Included</span>
              <% end %>
            </td>
            <td class="text-center">
              <%= button_to excluded ? "Include" : "Exclude",
                    toggle_exclusion_admin_analytics_path(user_id: user.id, period: @period),
                    class: "admin-btn admin-btn-sm",
                    style: excluded ? "background: rgba(31, 136, 61, 0.8);" : "background: #6c757d;" %>
            </td>
          </tr>
        <% end %>
        <% if @top_users_for_exclusion.size > 5 %>
          <tr data-expand-target="trigger" data-action="click->expand#toggle" style="cursor: pointer;">
            <td colspan="4" class="text-center" style="color: #e10600; font-size: 13px; font-weight: 600;">
              <span data-expand-target="label" data-show-text="Show <%= @top_users_for_exclusion.size - 5 %> more users">Show <%= @top_users_for_exclusion.size - 5 %> more users</span>
            </td>
          </tr>
          <% @top_users_for_exclusion.drop(5).each do |user| %>
            <% excluded = @excluded_ids.include?(user.id) %>
            <tr data-expand-target="content" style="display: none;">
              <td><%= user.username || user.email %></td>
              <td class="text-center"><%= number_with_delimiter(user.total_visits) %></td>
              <td class="text-center">
                <% if excluded %>
                  <span class="admin-badge" style="background: #6c757d;">Excluded</span>
                <% else %>
                  <span class="admin-badge" style="background: rgba(31, 136, 61, 0.8);">Included</span>
                <% end %>
              </td>
              <td class="text-center">
                <%= button_to excluded ? "Include" : "Exclude",
                      toggle_exclusion_admin_analytics_path(user_id: user.id, period: @period),
                      class: "admin-btn admin-btn-sm",
                      style: excluded ? "background: rgba(31, 136, 61, 0.8);" : "background: #6c757d;" %>
              </td>
            </tr>
          <% end %>
        <% end %>
      </tbody>
    </table>
  </div>
</div>

<% if @daily_visits.any? %>
  <h3 style="margin-top: 32px;">Daily Visits</h3>
  <div class="card card-flush" style="margin-top: 8px;">
    <div style="width:100%; height:240px;">
      <%= custom_chart({
        tooltip: { trigger: "axis" },
        grid: { left: 10, right: 16, top: 20, bottom: 10, containLabel: true },
        backgroundColor: "transparent",
        xAxis: {
          type: "category",
          data: @daily_visits.keys.map { |d| d.strftime("%b %d") },
          axisLabel: { color: "#666", fontSize: 10 },
          axisLine: { lineStyle: { color: "#333" } }
        },
        yAxis: {
          type: "value",
          axisLabel: { color: "#666" },
          splitLine: { lineStyle: { color: "rgba(255,255,255,0.04)" } }
        },
        series: [{
          name: "Visits",
          type: "bar",
          data: @daily_visits.values,
          itemStyle: { color: "#e10600" }
        }]
      }) %>
    </div>
  </div>
<% end %>

<% if @top_pages.any? %>
  <h3 style="margin-top: 32px;">Top Pages</h3>
  <div class="card card-flush" style="margin-top: 8px;">
    <table class="admin-table">
      <thead>
        <tr>
          <th>Page</th>
          <th class="text-center">Views</th>
        </tr>
      </thead>
      <tbody>
        <% @top_pages.each do |(controller, action), count| %>
          <tr>
            <td><%= controller %>#<%= action %></td>
            <td class="text-center"><%= number_with_delimiter(count) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<h3 style="margin-top: 32px;">User Activity</h3>
<div class="card card-flush" style="margin-top: 8px;">
  <table class="admin-table">
    <thead>
      <tr>
        <th>User</th>
        <th class="text-center">Visits</th>
        <th>Last Seen</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @users_with_activity.each do |user| %>
        <tr>
          <td><%= user.username || user.email %></td>
          <td class="text-center"><%= user.visit_count %></td>
          <td><%= time_ago_in_words(user.last_seen) %> ago</td>
          <td><%= link_to "View", admin_analytic_path(user), class: "admin-btn admin-btn-sm" %></td>
        </tr>
      <% end %>
      <% if @users_with_activity.empty? %>
        <tr><td colspan="4" class="text-center" style="padding: 24px; color: #666;">No logged-in user activity yet</td></tr>
      <% end %>
    </tbody>
  </table>
</div>
