<nav class="navbar" data-controller="navbar" aria-label="Main navigation">
    <div class="home">
        <%= link_to root_path do %>
            <span class="logo-f1">F1</span><span class="logo-elo">ELO</span>
        <% end %>
    </div>
    <button class="menu-toggle" data-action="click->navbar#toggleMenu" aria-label="Toggle navigation menu" aria-expanded="false" data-navbar-target="toggle">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
    </button>
    <div class="links" data-navbar-target="links" role="menubar">
        <%= link_to "Standings", root_path, class: "mobile-nav-item #{"active" if current_page?(root_path)}", role: "menuitem" %>

        <div class="nav-dropdown mobile-nav-item" data-controller="dropdown" role="none">
            <a href="#" class="nav-dropdown-toggle <%= 'active' if request.path.start_with?('/drivers') %>" data-action="click->dropdown#toggle keydown->dropdown#keydown" role="menuitem" aria-haspopup="true" aria-expanded="false" data-dropdown-target="trigger">
                Drivers <i class="fa-solid fa-chevron-down"></i>
            </a>
            <div class="nav-dropdown-menu" data-dropdown-target="menu" role="menu">
                <%= link_to "#{current_season.year} Grid", grid_drivers_path, class: ("active" if current_page?(grid_drivers_path)), role: "menuitem" %>
                <%= link_to "All Drivers", drivers_path, class: ("active" if current_page?(drivers_path)), role: "menuitem" %>
                <%= link_to "Compare", compare_drivers_path, class: ("active" if current_page?(compare_drivers_path)), role: "menuitem" %>
            </div>
        </div>

        <div class="nav-dropdown mobile-nav-item" data-controller="dropdown" role="none">
            <a href="#" class="nav-dropdown-toggle <%= 'active' if request.path.start_with?('/races') %>" data-action="click->dropdown#toggle keydown->dropdown#keydown" role="menuitem" aria-haspopup="true" aria-expanded="false" data-dropdown-target="trigger">
                Races <i class="fa-solid fa-chevron-down"></i>
            </a>
            <div class="nav-dropdown-menu" data-dropdown-target="menu" role="menu">
                <%= link_to "#{current_season.year} Calendar", calendar_races_path, class: ("active" if current_page?(calendar_races_path)), role: "menuitem" %>
                <%= link_to "All Races", races_path, class: ("active" if current_page?(races_path)), role: "menuitem" %>
            </div>
        </div>

        <div class="nav-dropdown mobile-nav-item" data-controller="dropdown" role="none">
            <a href="#" class="nav-dropdown-toggle <%= 'active' if request.path.start_with?('/constructors') %>" data-action="click->dropdown#toggle keydown->dropdown#keydown" role="menuitem" aria-haspopup="true" aria-expanded="false" data-dropdown-target="trigger">
                Constructors <i class="fa-solid fa-chevron-down"></i>
            </a>
            <div class="nav-dropdown-menu" data-dropdown-target="menu" role="menu">
                <%= link_to "#{current_season.year} Grid", grid_constructors_path, class: ("active" if current_page?(grid_constructors_path)), role: "menuitem" %>
                <%= link_to "All Constructors", constructors_path, class: ("active" if current_page?(constructors_path)), role: "menuitem" %>
            </div>
        </div>

        <div class="nav-dropdown mobile-nav-item" data-controller="dropdown" role="none">
            <a href="#" class="nav-dropdown-toggle <%= 'active' if request.path.start_with?('/seasons') %>" data-action="click->dropdown#toggle keydown->dropdown#keydown" role="menuitem" aria-haspopup="true" aria-expanded="false" data-dropdown-target="trigger">
                Seasons <i class="fa-solid fa-chevron-down"></i>
            </a>
            <div class="nav-dropdown-menu" data-dropdown-target="menu" role="menu">
                <% if current_season %>
                    <%= link_to "#{current_season.year} Season", season_path(current_season), role: "menuitem" %>
                <% end %>
                <%= link_to "All Seasons", seasons_path, class: ("active" if current_page?(seasons_path)), role: "menuitem" %>
            </div>
        </div>

        <div class="nav-dropdown mobile-nav-item" data-controller="dropdown" role="none">
            <a href="#" class="nav-dropdown-toggle <%= 'active' if request.path.start_with?('/stats') || request.path.start_with?('/circuits') %>" data-action="click->dropdown#toggle keydown->dropdown#keydown" role="menuitem" aria-haspopup="true" aria-expanded="false" data-dropdown-target="trigger">
                Stats <i class="fa-solid fa-chevron-down"></i>
            </a>
            <div class="nav-dropdown-menu" data-dropdown-target="menu" role="menu">
                <%= link_to "Stats Hub", stats_path, class: ("active" if current_page?(stats_path)), role: "menuitem" %>
                <div class="nav-dropdown-divider"></div>
                <%= link_to "Peak Elo", peak_elo_drivers_path, class: ("active" if current_page?(peak_elo_drivers_path)), role: "menuitem" %>
                <%= link_to "Active Elo", current_active_elo_drivers_path, class: ("active" if current_page?(current_active_elo_drivers_path)), role: "menuitem" %>
                <%= link_to "By Nationality", by_nationality_drivers_path, class: ("active" if current_page?(by_nationality_drivers_path)), role: "menuitem" %>
                <div class="nav-dropdown-divider"></div>
                <%= link_to "Race Wins & Podiums", race_wins_path, class: ("active" if current_page?(race_wins_path)), role: "menuitem" %>
                <%= link_to "World Champions", winners_races_path, class: ("active" if current_page?(winners_races_path)), role: "menuitem" %>
                <%= link_to "Champion Timeline", champion_timeline_path, class: ("active" if current_page?(champion_timeline_path)), role: "menuitem" %>
                <%= link_to "Highest Race Elos", highest_elo_races_path, class: ("active" if current_page?(highest_elo_races_path)), role: "menuitem" %>
                <div class="nav-dropdown-divider"></div>
                <%= link_to "Elo Milestones", elo_milestones_path, class: ("active" if current_page?(elo_milestones_path)), role: "menuitem" %>
                <%= link_to "Badges", badges_path, class: ("active" if current_page?(badges_path)), role: "menuitem" %>
                <%= link_to "Circuits", circuits_path, class: ("active" if request.path.start_with?('/circuits')), role: "menuitem" %>
                <div class="nav-dropdown-divider"></div>
                <%= link_to "Constructor Elo", elo_rankings_constructors_path, class: ("active" if current_page?(elo_rankings_constructors_path)), role: "menuitem" %>
                <%= link_to "Team Lineages", families_constructors_path, class: ("active" if current_page?(families_constructors_path)), role: "menuitem" %>
                <%= link_to "Best Pairings", best_pairings_constructors_path, class: ("active" if current_page?(best_pairings_constructors_path)), role: "menuitem" %>
                <%= link_to "Fan Standings", fan_standings_path, class: ("active" if current_page?(fan_standings_path)), role: "menuitem" %>
            </div>
        </div>

        <%= link_to "Elo", elo_path, class: "mobile-nav-item #{"active" if current_page?(elo_path)}", role: "menuitem" %>
        <div class="nav-dropdown mobile-nav-item" data-controller="dropdown" role="none">
            <a href="#" class="nav-dropdown-toggle <%= 'active' if request.path.start_with?('/fantasy') || request.path.start_with?('/stocks') || request.path.start_with?('/leaderboard') %>" data-action="click->dropdown#toggle keydown->dropdown#keydown" role="menuitem" aria-haspopup="true" aria-expanded="false" data-dropdown-target="trigger">
                Fantasy <i class="fa-solid fa-chevron-down"></i>
            </a>
            <div class="nav-dropdown-menu" data-dropdown-target="menu" role="menu">
                <% if current_user %>
                    <% portfolio = current_user.fantasy_portfolio_for(current_season) %>
                    <% stock_portfolio = current_user.fantasy_stock_portfolio_for(current_season) %>
                    <% if portfolio %>
                        <%= link_to "My Portfolio", fantasy_overview_path(current_user.username), class: ("active" if request.path.include?("/fantasy/u/")), role: "menuitem" %>
                        <% if stock_portfolio %>
                            <%= link_to "Market", market_fantasy_stock_portfolio_path(stock_portfolio), class: ("active" if request.path.include?("/market")), role: "menuitem" %>
                        <% end %>
                    <% else %>
                        <%= link_to "Create Portfolio", new_fantasy_portfolio_path, role: "menuitem" %>
                    <% end %>
                    <div class="nav-dropdown-divider"></div>
                <% end %>
                <%= link_to "Leaderboard", combined_leaderboard_path, class: ("active" if request.path.start_with?('/leaderboard')), role: "menuitem" %>
                <div class="nav-dropdown-divider"></div>
                <%= link_to "How it Works", fantasy_guide_path, class: ("active" if current_page?(fantasy_guide_path)), role: "menuitem" %>
            </div>
        </div>
        <% if current_user&.admin? %>
            <%= link_to admin_root_path, class: "admin-link mobile-nav-item", "aria-label": "Admin panel" do %>
                <i class="fa-solid fa-lock"></i>
            <% end %>
        <% end %>

        <%# Desktop auth link (hidden on mobile) %>
        <% if current_user %>
            <%= link_to user_settings_path(current_user.username), class: "nav-auth-link nav-auth-desktop", role: "menuitem", title: "Settings" do %>
                <i class="fa-solid fa-gear"></i>
            <% end %>
            <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-auth-link nav-auth-desktop", role: "menuitem" do %>
                <i class="fa-solid fa-right-from-bracket"></i> <span class="nav-auth-label">Sign Out</span>
            <% end %>
        <% else %>
            <%= link_to new_user_session_path, class: "nav-auth-link nav-auth-desktop", role: "menuitem" do %>
                <i class="fa-solid fa-right-to-bracket"></i> <span class="nav-auth-label">Sign In</span>
            <% end %>
        <% end %>

        <%# Mobile auth footer (hidden on desktop) %>
        <div class="mobile-nav-footer mobile-nav-item">
            <% if current_user %>
                <%= link_to user_settings_path(current_user.username), class: "nav-auth-link", role: "menuitem" do %>
                    <i class="fa-solid fa-gear"></i> Settings
                <% end %>
                <%= link_to destroy_user_session_path, data: { turbo_method: :delete }, class: "nav-auth-link", role: "menuitem" do %>
                    <i class="fa-solid fa-right-from-bracket"></i> Sign Out
                <% end %>
            <% else %>
                <%= link_to new_user_session_path, class: "nav-auth-link", role: "menuitem" do %>
                    <i class="fa-solid fa-right-to-bracket"></i> Sign In
                <% end %>
            <% end %>
        </div>
    </div>
    <div class="mobile-overlay" data-navbar-target="overlay" data-action="click->navbar#closeOverlay"></div>
</nav>
