<div class="homepage-container" data-controller="compare" data-compare-search-url-value="<%= search_drivers_path %>">
    <div class="table-header">
        <h3>Compare Drivers</h3>
    </div>

    <div class="card compare-search-card">
        <div class="compare-input-wrapper">
            <input type="text"
                   class="driver-search-input"
                   placeholder="Search for a driver..."
                   data-compare-target="input"
                   data-action="input->compare#search"
                   autocomplete="off">
            <div class="compare-suggestions" data-compare-target="suggestions"></div>
        </div>
        <div class="compare-chips" data-compare-target="chips">
            <% if @drivers.present? %>
                <% @drivers.each do |driver| %>
                    <span class="compare-chip" data-preloaded-id="<%= driver.id %>" data-preloaded-name="<%= driver.fullname %>" data-preloaded-peak-elo="<%= driver.peak_elo&.round %>">
                        <%= driver.fullname %>
                        <button data-action="click->compare#remove" data-id="<%= driver.id %>">&times;</button>
                    </span>
                <% end %>
            <% end %>
        </div>
        <% if @drivers.blank? %>
            <p class="compare-hint">Select 2-7 drivers to compare their Elo ratings over time</p>
        <% end %>
    </div>

    <% if @drivers.present? && @drivers.size >= 2 %>
        <div class="card">
            <div class="chart-header">
                <h4>Elo Rating Comparison</h4>
            </div>
            <%= custom_chart Graphs::Compare.new(drivers: @drivers).data %>
        </div>

        <div class="card card-flush">
            <div class="table-scroll-wrapper">
                <table class="current-driver-standings compact">
                    <thead>
                        <tr>
                            <th>Driver</th>
                            <th class="text-center">Peak Elo</th>
                            <th class="text-center">Current Elo</th>
                            <th class="text-center">Races</th>
                            <th class="text-center">Wins</th>
                            <th class="text-center">Podiums</th>
                            <th class="text-center">Championships</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @drivers.sort_by { |d| -(d.display_peak_elo || 0) }.each do |driver| %>
                            <tr>
                                <td>
                                    <% if driver.country.present? %>
                                        <img src="https://flagsapi.com/<%= driver.country.two_letter_country_code %>/shiny/16.png"
                                             alt="<%= driver.country.name %>" loading="lazy" onerror="this.style.display='none'"
                                             style="vertical-align: middle; margin-right: 4px;">
                                    <% end %>
                                    <%= link_to driver.fullname, driver_path(driver) %>
                                </td>
                                <td class="text-center"><%= driver.display_peak_elo&.round %></td>
                                <td class="text-center"><%= driver.display_elo&.round %></td>
                                <td class="text-center"><%= driver.number_of_races %></td>
                                <td class="text-center"><%= driver.wins || 0 %></td>
                                <td class="text-center"><%= driver.podiums || 0 %></td>
                                <td class="text-center">
                                    <%= driver.driver_standings.select { |ds| ds.season_end && ds.position == 1 }.count %>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    <% end %>
</div>
