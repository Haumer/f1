<div class="homepage-container">
    <div class="page-hero page-hero-compact">
        <div class="page-hero-bg"></div>
        <div class="page-hero-content">
            <h1 class="page-hero-title">All Drivers</h1>
            <p class="page-hero-meta">Top 100 by race wins</p>
        </div>
    </div>
    <div class="driver-search-wrapper">
        <%= simple_form_for :search, url: drivers_path, method: :get, html: { class: "search-form" }, data: {
                controller: "search-form",
                search_form_target: "form",
                turbo_frame: "drivers",
                turbo_action: "advance",
                action: "input->search-form#submit"
            } do |f| %>
            <%= f.input :query, placeholder: "Search by name",
                autocomplete: "off",
                label: false,
                input_html: { class: "driver-search-input" },
                data: { action: "input->search-form#submit" } %>
            <%= f.submit class: "visually-hidden", tabindex: "-1" %>
        <% end %>
    </div>
    <%= turbo_frame_tag "drivers" do %>
        <%= render 'drivers', drivers: @drivers %>
    <% end %>
</div>
