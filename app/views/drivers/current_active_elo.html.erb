<div class="homepage-container">
    <div class="table-header">
        <h3>Active Driver Elo Ratings</h3>
    </div>
    <div class="card">
        <%= custom_chart Graphs::ActiveEloBar.new(drivers: @drivers).data %>
    </div>
    <div class="card card-flush">
        <div class="table-scroll-wrapper">
        <table class="current-driver-standings compact">
            <thead>
                <tr>
                    <th class="text-center">#</th>
                    <th></th>
                    <th>Driver</th>
                    <th></th>
                    <th class="text-center">Elo</th>
                    <th class="text-center">Peak</th>
                </tr>
            </thead>
            <tbody>
                <% @drivers.each_with_index do |driver, index| %>
                    <tr class="<%= 'podium-row podium-p' + (index + 1).to_s if index < 3 %>">
                        <td class="text-center"><%= index + 1 %></td>
                        <td class="icon-cell">
                            <% if driver.country.present? %>
                                <img src="https://flagsapi.com/<%= driver.country.two_letter_country_code %>/shiny/24.png" alt="<%= driver.country.name %>" loading="lazy" onerror="this.style.display='none'">
                            <% end %>
                        </td>
                        <td>
                            <%= link_to driver_path(driver) do %>
                                <%= driver.forename[0] %>.<%= driver.surname %>
                            <% end %>
                        </td>
                        <td>
                            <% if driver.current_constructor %>
                                <img src="<%= driver.current_constructor.logo_url %>" alt="<%= driver.current_constructor.name %>" class="constructor-logo-xs">
                            <% end %>
                        </td>
                        <td class="text-center"><%= driver.display_elo&.round %></td>
                        <td class="text-center"><%= driver.display_peak_elo&.round %></td>
                    </tr>
                <% end %>
            </tbody>
        </table>
        </div>
    </div>
</div>
