<% content_for(:title) { @driver.fullname } %>
<% content_for(:description) { "#{@driver.fullname} — Elo rating, career stats, race results, and head-to-head comparisons on F1 Elo." } %>
<div class="homepage-container">
<div class="driver-hero">
    <div class="driver-hero-bg"></div>
    <div class="driver-hero-content">
        <div class="driver-hero-info">
            <div class="driver-hero-text">
                <%= flag_image(@driver, size: 32) %>
                <h1 class="driver-hero-name"><%= @driver.fullname %></h1>
                <% if @driver.current_constructor %>
                    <span class="driver-hero-team"><%= link_to @driver.current_constructor.name, constructor_path(@driver.current_constructor) %></span>
                <% end %>
                <div class="driver-hero-titles">
                    <% if @season_1st_place_finishes.present? %>
                        <span class="title-badge champion"><%= @season_1st_place_finishes.count %>x Champion</span>
                    <% end %>
                    <% if @season_2nd_place_finishes.present? %>
                        <span class="title-badge runner-up"><%= @season_2nd_place_finishes.count %>x Runner Up</span>
                    <% end %>
                    <% if @season_3rd_place_finishes.present? %>
                        <span class="title-badge third"><%= @season_3rd_place_finishes.count %>x 3rd Place</span>
                    <% end %>
                </div>
            </div>
            <div class="driver-hero-elo">
                <div class="driver-hero-elo-stat">
                    <span class="driver-hero-elo-value"><%= elo_link(@driver.display_elo) %></span>
                    <span class="driver-hero-elo-label"><%= @driver.active ? "Current Elo" : "Final Elo" %></span>
                </div>
                <div class="driver-hero-elo-stat">
                    <span class="driver-hero-elo-value"><%= elo_link(@driver.display_peak_elo) %></span>
                    <span class="driver-hero-elo-label">Peak Elo</span>
                </div>
                <% if @elo_tier %>
                    <div class="driver-hero-elo-stat">
                        <span class="elo-tier-badge elo-tier-<%= @elo_tier[:css] %>"><%= @elo_tier[:label] %></span>
                        <span class="driver-hero-elo-label">Tier</span>
                    </div>
                <% end %>
            </div>
        </div>
    </div>
</div>

<div class="layout-grid">
    <div class="grid-sidebar">
        <div class="card driver-card">
            <img src="<%= @driver.display_image_url %>" alt="<%= @driver.fullname %>" class="driver-photo" loading="lazy" onerror="this.style.display='none'">

            <%= link_to compare_drivers_path(driver_ids: @driver.id), class: "driver-compare-btn" do %>
                <i class="fa-solid fa-scale-balanced"></i> Compare
            <% end %>

            <div class="profile-section">
                <div class="section-label">Race Podiums</div>
                <div class="race-trophy-case">
                    <div class="trophy-col">
                        <div class="place-2"><i class="fa-solid fa-trophy"></i></div>
                        <div class="trophy-count"><%= @race_result_counts[2] || 0 %></div>
                    </div>
                    <div class="trophy-col trophy-first">
                        <div class="place-1"><i class="fa-solid fa-trophy"></i></div>
                        <div class="trophy-count"><%= @race_result_counts[1] || 0 %></div>
                    </div>
                    <div class="trophy-col">
                        <div class="place-3"><i class="fa-solid fa-trophy"></i></div>
                        <div class="trophy-count"><%= @race_result_counts[3] || 0 %></div>
                    </div>
                </div>
                <div class="fourth-place">
                    <span class="place-4"><i class="fa-solid fa-trophy"></i></span> x<%= @race_result_counts[4] || 0 %>
                </div>
            </div>

            <div class="profile-section">
                <div class="section-label">Seasons</div>
                <div class="profile-seasons">
                    <% @driver.driver_standings.select { |ds| ds.season_end }.sort_by { |ds| ds.race.season.year }.reverse.each do |driver_standing| %>
                        <div class="season-badge place-<%= driver_standing.position %>">
                            <%= link_to driver_standing.race.season.year, season_path(driver_standing.race.season), class: "place-#{driver_standing.position}" %>
                        </div>
                    <% end %>
                </div>
            </div>

            <div class="profile-section">
                <div class="section-label">Elo Rank</div>
                <div class="elo-rank-badges">
                    <% if @peak_elo_rank %>
                        <div class="rank-badge">
                            #<%= @peak_elo_rank %> <span class="rank-context">all-time peak</span>
                        </div>
                    <% end %>
                    <% if @driver.active && @active_elo_rank %>
                        <div class="rank-badge">
                            #<%= @active_elo_rank %> <span class="rank-context">active</span>
                        </div>
                    <% end %>
                </div>
            </div>

            <div class="profile-section">
                <div class="section-label">Career Stats</div>
                <div class="career-stats-grid">
                    <div class="career-stat-row">
                        <span class="career-stat-label">Races</span>
                        <span class="career-stat-value"><%= @driver.race_results.size %></span>
                    </div>
                    <div class="career-stat-row">
                        <span class="career-stat-label">Finished</span>
                        <span class="career-stat-value"><%= @driver.finished_races || 0 %></span>
                    </div>
                    <div class="career-stat-row">
                        <span class="career-stat-label">DNFs</span>
                        <span class="career-stat-value"><%= (@driver.crash_races || 0) + (@driver.technichal_failures_races || 0) + (@driver.disqualified_races || 0) %></span>
                    </div>
                    <div class="career-stat-row career-stat-sub">
                        <span class="career-stat-label">Accident / Other</span>
                        <span class="career-stat-value"><%= @driver.crash_races || 0 %></span>
                    </div>
                    <div class="career-stat-row career-stat-sub">
                        <span class="career-stat-label">Mechanical</span>
                        <span class="career-stat-value"><%= @driver.technichal_failures_races || 0 %></span>
                    </div>
                    <% if (@driver.disqualified_races || 0) > 0 %>
                        <div class="career-stat-row career-stat-sub">
                            <span class="career-stat-label">Disqualified</span>
                            <span class="career-stat-value"><%= @driver.disqualified_races %></span>
                        </div>
                    <% end %>
                    <% total_races = @driver.race_results.size %>
                    <% if total_races > 0 %>
                        <div class="career-stat-row">
                            <span class="career-stat-label">Win Rate</span>
                            <span class="career-stat-value"><%= ((@driver.wins || 0).to_f / total_races * 100).round(1) %>%</span>
                        </div>
                        <div class="career-stat-row">
                            <span class="career-stat-label">Podium Rate</span>
                            <span class="career-stat-value"><%= ((@driver.podiums || 0).to_f / total_races * 100).round(1) %>%</span>
                        </div>
                    <% end %>
                </div>
            </div>

            <% if @constructor_history.any? %>
                <div class="profile-section">
                    <div class="section-label">Constructor History</div>
                    <div class="constructor-history">
                        <% @constructor_history.each do |stint| %>
                            <% color = constructor_color(stint[:constructor]) %>
                            <%= link_to constructor_path(stint[:constructor]), class: "constructor-stint", style: "--stint-color: #{color}" do %>
                                <div class="stint-color-bar"></div>
                                <div class="stint-info">
                                    <div class="stint-header">
                                        <% if stint[:constructor].logo_url.present? %>
                                            <img src="<%= stint[:constructor].logo_url %>" alt="" class="stint-logo" loading="lazy" onerror="this.style.display='none'">
                                        <% end %>
                                        <span class="stint-name"><%= stint[:constructor].name %></span>
                                    </div>
                                    <span class="stint-years"><%= stint[:years] %></span>
                                </div>
                                <div class="stint-stats">
                                    <span class="stint-stat"><%= stint[:races] %> <span class="stint-stat-lbl">races</span></span>
                                    <% if stint[:wins] > 0 %>
                                        <span class="stint-stat stint-wins"><%= stint[:wins] %> <span class="stint-stat-lbl"><%= stint[:wins] == 1 ? 'win' : 'wins' %></span></span>
                                    <% end %>
                                    <% if stint[:podiums] > 0 && stint[:podiums] != stint[:wins] %>
                                        <span class="stint-stat"><%= stint[:podiums] %> <span class="stint-stat-lbl"><%= stint[:podiums] == 1 ? 'podium' : 'podiums' %></span></span>
                                    <% end %>
                                </div>
                            <% end %>
                        <% end %>
                    </div>
                </div>
            <% end %>

            <% if @badges.any? %>
                <div class="profile-section">
                    <div class="section-label">Achievements</div>
                    <div class="achievement-badges">
                        <% @badges.each do |badge| %>
                            <% tier_label = { "gold" => "🥇 #1 all-time", "silver" => "🥈 #2 all-time", "bronze" => "🥉 #3 all-time" }[badge.tier] %>
                            <% is_circuit_king = badge.key.start_with?("circuit_king") %>
                            <div class="achievement-badge<%= " tier-#{badge.tier}" if badge.tier %><%= " badge-icon-only" unless is_circuit_king %>" data-tooltip="<%= badge.label %> — <%= badge.description %><%= " — #{tier_label}" if tier_label %>">
                                <i class="<%= badge.icon %>"></i>
                                <% if is_circuit_king %>
                                    <span class="achievement-label"><%= badge.label.sub("King of ", "") %></span>
                                <% end %>
                            </div>
                        <% end %>
                    </div>
                </div>
            <% end %>
        </div>

    </div>
    <div class="grid-main">
        <div class="chart-header">
            <h4>Elo Rating Over Time</h4>
        </div>
        <div class="driver-chart-full">
            <%= custom_chart Graphs::Line.new(driver: @driver).driver_data %>
        </div>
        <span class="data-source">Data: Elo ratings computed from race finishing positions &middot; <%= @driver.race_results.size %> races</span>
        <div class="card card-flush">
            <div class="table-scroll-wrapper">
            <table class="driver-race-results current-driver-standings compact">
                <thead>
                    <tr>
                        <th class="text-center">#</th>
                        <th class="text-center">Elo</th>
                        <th class="text-center d-none d-md-table-cell">Old</th>
                        <th class="d-none d-md-table-cell"></th>
                        <th class="text-center d-none d-md-table-cell">New</th>
                        <th class="text-center d-none d-sm-table-cell">Status</th>
                        <th class="d-none d-md-table-cell"></th>
                        <th>Circuit</th>
                        <th class="d-none d-sm-table-cell">Date</th>
                        <th class="d-none d-lg-table-cell">Race</th>
                    </tr>
                </thead>
                <tbody>
                    <% previous_year = nil %>
                    <% @driver.race_results.sort_by { |r| r.race.date }.reverse.each do |race_result| %>
                        <% current_year = race_result.race.date.year %>
                        <% if current_year != previous_year %>
                            <tr class="season-divider">
                                <td colspan="10"><strong><%= current_year %> Season</strong></td>
                            </tr>
                            <% previous_year = current_year %>
                        <% end %>
                        <tr>
                            <td class="text-center"><%= race_result.position_order %></td>
                            <td class="text-center">
                                <% if race_result.display_gained_elo? %>
                                    <span class="text-green"><i class="fa-solid fa-caret-up"></i> +<%= race_result.display_elo_diff.round(1) %></span>
                                <% else %>
                                    <span class="text-red"><i class="fa-solid fa-caret-down"></i> <%= race_result.display_elo_diff.round(1) %></span>
                                <% end %>
                            </td>
                            <td class="text-center d-none d-md-table-cell"><%= elo_link(race_result.display_old_elo) %></td>
                            <td class="text-center d-none d-md-table-cell"><i class="fa-solid fa-caret-right"></i></td>
                            <td class="text-center d-none d-md-table-cell <%= 'underline' if race_result.driver.display_peak_elo == race_result.display_new_elo %>"><%= elo_link(race_result.display_new_elo) %></td>
                            <td class="text-center d-none d-sm-table-cell <%= finished?(race_result.status.status_type) ? 'text-green' : 'text-red' %>"><%= race_result.status.status_type %></td>
                            <td class="text-center d-none d-md-table-cell">
                                <%= link_to constructor_path(race_result.constructor) do %>
                                    <% if race_result.constructor.logo_url.present? %>
                                        <img src="<%= race_result.constructor.logo_url %>" alt="<%= race_result.constructor.name %>" class="constructor-logo-sm" onerror="this.style.display='none'">
                                    <% else %>
                                        <span class="text-secondary"><%= race_result.constructor.name %></span>
                                    <% end %>
                                <% end %>
                            </td>
                            <td><%= link_to race_result.race.circuit.name, circuit_path(race_result.race.circuit) %></td>
                            <td class="d-none d-sm-table-cell"><%= race_result.race.date.strftime("%b %d, %Y") %></td>
                            <td class="d-none d-lg-table-cell"><%= link_to "Round #{race_result.race.round}", race_path(race_result.race) %></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
            </div>
        </div>
    </div>
</div>
</div>
