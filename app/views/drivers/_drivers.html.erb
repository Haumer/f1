<% if drivers.any? %>
    <div class="card card-flush">
        <div class="table-scroll-wrapper">
            <table class="current-driver-standings compact" data-controller="sortable-table">
                <thead>
                    <tr>
                        <th class="text-center">#</th>
                        <th class="d-none d-sm-table-cell"></th>
                        <th data-sort="text">Driver</th>
                        <th class="d-none d-md-table-cell">Teams</th>
                        <th class="text-center" data-sort="num">Peak Elo</th>
                        <th class="text-center d-none d-sm-table-cell" data-sort="num"><i class="fa-solid fa-trophy" style="color: #C9B037;"></i></th>
                        <th class="text-center d-none d-md-table-cell" data-sort="num"><span style="color: #B4B4B4;">2nd</span></th>
                        <th class="text-center d-none d-md-table-cell" data-sort="num"><span style="color: #AD8A56;">3rd</span></th>
                        <th class="text-center d-none d-lg-table-cell" data-sort="num">Races</th>
                    </tr>
                </thead>
                <tbody>
                    <% drivers.each_with_index do |driver, idx| %>
                        <tr class="<%= 'podium-row podium-p' + (idx + 1).to_s if idx < 3 %>">
                            <td class="text-center position-cell"><%= idx + 1 %></td>
                            <td class="icon-cell d-none d-sm-table-cell">
                                <%= flag_image(driver, size: 24) %>
                            </td>
                            <td>
                                <%= link_to driver_path(driver), data: { turbo: false } do %>
                                    <%= driver.forename[0] %>.<%= driver.surname %>
                                <% end %>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <% recent_constructors = driver.season_drivers.sort_by { |sd| -(sd.season&.year.to_i) }.map(&:constructor).uniq(&:id).first(3) %>
                                <div class="driver-teams-cell">
                                    <% recent_constructors.each_with_index do |constructor, cidx| %>
                                        <% color = constructor_color(constructor) %>
                                        <% if constructor.logo_url.present? %>
                                            <%= link_to constructor_path(constructor), title: constructor.name do %>
                                                <img src="<%= constructor.logo_url %>" alt="<%= constructor.name %>" class="constructor-logo-xs" onerror="this.parentNode.innerHTML='<span class=driver-team-tag style=--tc:<%= color || '#555' %>><%= j constructor.name %></span>'">
                                            <% end %>
                                        <% else %>
                                            <%= link_to constructor_path(constructor) do %>
                                                <span class="driver-team-tag" <% if color %>style="--tc: <%= color %>"<% end %>><%= constructor.name %></span>
                                            <% end %>
                                        <% end %>
                                    <% end %>
                                </div>
                            </td>
                            <td class="text-center"><%= elo_link(driver.display_peak_elo) %></td>
                            <td class="text-center d-none d-sm-table-cell"><%= driver.wins.to_i > 0 ? driver.wins : '—' %></td>
                            <td class="text-center d-none d-md-table-cell"><%= driver.second_places.to_i > 0 ? driver.second_places : '—' %></td>
                            <td class="text-center d-none d-md-table-cell"><%= driver.third_places.to_i > 0 ? driver.third_places : '—' %></td>
                            <td class="text-center text-secondary d-none d-lg-table-cell"><%= driver.race_count %></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>
<% else %>
    <div class="card">
        <div class="empty-state">
            <i class="fa-solid fa-magnifying-glass"></i>
            <h3>No drivers found</h3>
            <p>Try a different search term or clear your search.</p>
        </div>
    </div>
<% end %>
