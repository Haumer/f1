<% content_for(:title) { "All-Time Peak Elo Rankings" } %>
<% content_for(:description) { "F1 drivers ranked by their highest-ever Elo rating — the all-time greats measured by peak performance." } %>
<div class="homepage-container">
    <div class="page-hero page-hero-compact">
        <div class="page-hero-bg"></div>
        <div class="page-hero-content">
            <span class="page-hero-label">Rankings</span>
            <h1 class="page-hero-title">All-Time Peak Elo</h1>
        </div>
    </div>
    <% min_elo = Setting.use_elo_v2? ? 2350 : 1250 %>
    <%= custom_chart({
        backgroundColor: 'transparent',
        xAxis: { type: "category", data: @drivers.map(&:surname), axisLabel: { rotate: 45, fontSize: 10, color: 'rgba(255,255,255,0.7)' } },
        yAxis: { type: "value", min: min_elo, axisLabel: { color: 'rgba(255,255,255,0.7)' } },
        series: [{ type: "bar", data: @drivers.map { |d| d.display_peak_elo.round(1) }, itemStyle: { color: @page_accent || '#e10600' } }],
        tooltip: { trigger: "axis", axisPointer: { type: 'shadow' } },
        grid: { bottom: 80, left: 10, right: 10, containLabel: true }
    }) %>

    <div class="card card-flush">
        <div class="table-scroll-wrapper">
            <table class="current-driver-standings compact" data-controller="sortable-table">
                <thead>
                    <tr>
                        <th class="text-center">#</th>
                        <th class="d-none d-sm-table-cell"></th>
                        <th data-sort="text">Driver</th>
                        <th class="d-none d-md-table-cell"></th>
                        <th class="text-center" data-sort="num">Peak Elo</th>
                        <th class="text-center d-none d-sm-table-cell" data-sort="text">Tier</th>
                        <th class="d-none d-md-table-cell" data-sort="text">Race</th>
                        <th class="d-none d-md-table-cell" data-sort="num">Year</th>
                    </tr>
                </thead>
                <tbody>
                    <% @drivers.each_with_index do |driver, idx| %>
                        <% peak_rr = @peak_race_by_driver[driver.id] %>
                        <tr class="<%= 'podium-row podium-p' + (idx + 1).to_s if idx < 3 %>">
                            <td class="text-center position-cell"><%= idx + 1 %></td>
                            <td class="icon-cell d-none d-sm-table-cell">
                                <% if driver.country.present? %>
                                    <img src="https://flagsapi.com/<%= driver.country.two_letter_country_code %>/shiny/24.png" alt="<%= driver.country.name %>" loading="lazy" onerror="this.style.display='none'">
                                <% end %>
                            </td>
                            <td>
                                <%= link_to driver_path(driver) do %>
                                    <%= driver.forename[0] %>.<%= driver.surname %>
                                <% end %>
                            </td>
                            <td class="icon-cell d-none d-md-table-cell">
                                <% if peak_rr&.constructor&.logo_url.present? %>
                                    <img src="<%= peak_rr.constructor.logo_url %>" alt="<%= peak_rr.constructor.name %>" class="constructor-logo-sm" onerror="this.style.display='none'">
                                <% end %>
                            </td>
                            <td class="text-center"><strong><%= elo_link(driver.display_peak_elo) %></strong></td>
                            <td class="text-center d-none d-sm-table-cell">
                                <% tier = elo_tier(driver.display_peak_elo) %>
                                <% if tier %>
                                    <span class="elo-tier-badge elo-tier-<%= tier[:css] %>"><%= tier[:label] %></span>
                                <% end %>
                            </td>
                            <td class="d-none d-md-table-cell">
                                <% if peak_rr %>
                                    <%= link_to peak_rr.race.circuit.name, race_path(peak_rr.race) %>
                                <% end %>
                            </td>
                            <td class="d-none d-md-table-cell"><%= peak_rr&.race&.date&.year %></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>
</div>
