<% content_for(:title) { "Settings" } %>
<% content_for(:description) { "Manage your F1 Elo account settings and profile." } %>
<div class="homepage-container">
    <div class="fantasy-dashboard-header">
        <div class="fantasy-dashboard-title">
            <h2>Settings</h2>
            <span class="fantasy-season">@<%= @user.username %></span>
        </div>
        <div class="fantasy-header-actions">
            <%= link_to fantasy_overview_path(@user.username), class: "fantasy-btn fantasy-btn-outline" do %>
                <i class="fa-solid fa-arrow-left"></i> Portfolio
            <% end %>
        </div>
    </div>

    <div class="settings-layout">
        <%# ═══ Profile Section ═══ %>
        <div class="settings-section">
            <div class="settings-section-header">
                <div class="settings-section-icon"><i class="fa-solid fa-user"></i></div>
                <div>
                    <h3>Profile</h3>
                    <p>Your public identity on the leaderboard</p>
                </div>
            </div>

            <%= form_with model: @user, url: user_settings_path(@user.username), method: :patch, local: true, class: "settings-form" do |f| %>
                <div class="settings-field">
                    <label class="settings-label" for="user_username">Username</label>
                    <div class="settings-input-wrapper">
                        <span class="settings-input-prefix">@</span>
                        <%= f.text_field :username, class: "settings-input settings-input--prefixed", autocomplete: "off", placeholder: "your_username" %>
                    </div>
                    <% if @user.errors[:username].any? %>
                        <span class="settings-error"><i class="fa-solid fa-circle-exclamation"></i> <%= @user.errors[:username].first %></span>
                    <% end %>
                </div>

                <div class="settings-field">
                    <label class="settings-label">Profile Visibility</label>
                    <label class="settings-toggle">
                        <input type="hidden" name="user[public_profile]" value="0">
                        <%= f.check_box :public_profile, class: "settings-toggle-input" %>
                        <span class="settings-toggle-track">
                            <span class="settings-toggle-thumb"></span>
                        </span>
                        <span class="settings-toggle-label">
                            <span class="settings-toggle-text">Public profile</span>
                            <span class="settings-toggle-hint">
                                <% if @user.public_profile? %>
                                    <i class="fa-solid fa-globe"></i> Visible at <code>fantasy/u/<%= @user.username %></code>
                                <% else %>
                                    <i class="fa-solid fa-lock"></i> Only you can see your portfolio
                                <% end %>
                            </span>
                        </span>
                    </label>
                </div>

                <div class="settings-actions">
                    <%= f.submit "Save Changes", class: "fantasy-btn fantasy-btn-primary" %>
                </div>
            <% end %>
        </div>

        <%# ═══ Security Section ═══ %>
        <div class="settings-section">
            <div class="settings-section-header">
                <div class="settings-section-icon"><i class="fa-solid fa-shield-halved"></i></div>
                <div>
                    <h3>Security</h3>
                    <p>Update your password</p>
                </div>
            </div>

            <%= form_with model: @user, url: user_settings_path(@user.username), method: :patch, local: true, class: "settings-form" do |f| %>
                <div class="settings-field">
                    <label class="settings-label" for="user_current_password">Current Password</label>
                    <%= f.password_field :current_password, class: "settings-input", autocomplete: "current-password", placeholder: "Enter current password" %>
                    <% if @user.errors[:current_password].any? %>
                        <span class="settings-error"><i class="fa-solid fa-circle-exclamation"></i> <%= @user.errors[:current_password].first %></span>
                    <% end %>
                </div>
                <div class="settings-field-row">
                    <div class="settings-field">
                        <label class="settings-label" for="user_password">New Password</label>
                        <%= f.password_field :password, class: "settings-input", autocomplete: "new-password", placeholder: "Min 6 characters" %>
                    </div>
                    <div class="settings-field">
                        <label class="settings-label" for="user_password_confirmation">Confirm</label>
                        <%= f.password_field :password_confirmation, class: "settings-input", autocomplete: "new-password", placeholder: "Repeat password" %>
                    </div>
                </div>
                <div class="settings-actions">
                    <%= f.submit "Update Password", class: "fantasy-btn fantasy-btn-primary" %>
                </div>
            <% end %>
        </div>

        <%# ═══ Account Info ═══ %>
        <div class="settings-section">
            <div class="settings-section-header">
                <div class="settings-section-icon"><i class="fa-solid fa-circle-info"></i></div>
                <div>
                    <h3>Account</h3>
                    <p>Your account details</p>
                </div>
            </div>

            <div class="settings-info-grid">
                <div class="settings-info-item">
                    <span class="settings-info-label"><i class="fa-solid fa-envelope"></i> Email</span>
                    <span class="settings-info-value"><%= @user.email %></span>
                </div>
                <div class="settings-info-item">
                    <span class="settings-info-label"><i class="fa-solid fa-calendar"></i> Member since</span>
                    <span class="settings-info-value"><%= @user.created_at.strftime("%B %d, %Y") %></span>
                </div>
            </div>
        </div>

        <%# ═══ Danger Zone ═══ %>
        <div class="settings-section settings-danger-zone">
            <div class="settings-section-header">
                <div class="settings-section-icon settings-section-icon--danger"><i class="fa-solid fa-triangle-exclamation"></i></div>
                <div>
                    <h3>Danger Zone</h3>
                    <p>Irreversible actions</p>
                </div>
            </div>

            <div class="settings-danger-content">
                <div class="settings-danger-item">
                    <div class="settings-danger-info">
                        <strong>Delete Account</strong>
                        <span>Permanently remove your account and all fantasy data. This cannot be undone.</span>
                    </div>
                    <%= button_to "Delete Account", registration_path(:user), method: :delete,
                        class: "fantasy-btn fantasy-btn-danger",
                        data: { turbo_confirm: "Are you sure? This will permanently delete your account and all fantasy data." } %>
                </div>
            </div>
        </div>
    </div>
</div>
