<% content_for(:title) { "Elo Milestones" } %>
<% content_for(:description) { "Historic Elo rating milestones in F1 — first drivers to reach each threshold and the races where they achieved it." } %>
<div class="homepage-container">
    <div class="page-back-link">
        <%= link_to stats_path do %>
            <i class="fa-solid fa-arrow-left"></i> Stats
        <% end %>
    </div>
    <div class="page-hero page-hero-compact">
        <div class="page-hero-bg"></div>
        <div class="page-hero-content">
            <span class="page-hero-label">Records</span>
            <h1 class="page-hero-title">Elo Milestones</h1>
        </div>
    </div>

    <%# Biggest Single-Race Elo Gain %>
    <div class="table-header">
        <h4><i class="fa-solid fa-arrow-trend-up text-green"></i> Biggest Single-Race Elo Gain</h4>
    </div>
    <div class="card card-flush" style="margin-bottom: 24px;">
        <div class="table-scroll-wrapper">
            <table class="current-driver-standings compact" data-controller="sortable-table">
                <thead>
                    <tr>
                        <th class="text-center" data-sort="num">#</th>
                        <th></th>
                        <th data-sort="text">Driver</th>
                        <th></th>
                        <th data-sort="text">Race</th>
                        <th data-sort="num">Year</th>
                        <th class="text-center" data-sort="num">Pos</th>
                        <th class="text-center" data-sort="num">Elo Change</th>
                    </tr>
                </thead>
                <tbody>
                    <% @biggest_gains.each_with_index do |rr, idx| %>
                        <tr class="<%= 'podium-row podium-p' + (idx + 1).to_s if idx < 3 %>">
                            <td class="text-center position-cell"><%= idx + 1 %></td>
                            <td class="icon-cell">
                                <%= flag_image(rr.driver, size: 24) %>
                            </td>
                            <td>
                                <%= link_to driver_path(rr.driver) do %>
                                    <%= rr.driver.forename[0] %>.<%= rr.driver.surname %>
                                <% end %>
                            </td>
                            <td class="icon-cell">
                                <% if rr.constructor&.logo_url.present? %>
                                    <img src="<%= rr.constructor.logo_url %>" alt="<%= rr.constructor.name %>" class="constructor-logo-sm" onerror="this.style.display='none'">
                                <% end %>
                            </td>
                            <td><%= link_to rr.race.circuit.name, race_path(rr.race) %></td>
                            <td><%= rr.race.year %></td>
                            <td class="text-center">P<%= rr.position_order %></td>
                            <td class="text-center text-green"><strong>+<%= rr.display_elo_diff.round %></strong></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>

    <%# Biggest Single-Race Elo Drop %>
    <div class="table-header">
        <h4><i class="fa-solid fa-arrow-trend-down text-red"></i> Biggest Single-Race Elo Drop</h4>
    </div>
    <div class="card card-flush" style="margin-bottom: 24px;">
        <div class="table-scroll-wrapper">
            <table class="current-driver-standings compact" data-controller="sortable-table">
                <thead>
                    <tr>
                        <th class="text-center" data-sort="num">#</th>
                        <th></th>
                        <th data-sort="text">Driver</th>
                        <th></th>
                        <th data-sort="text">Race</th>
                        <th data-sort="num">Year</th>
                        <th class="text-center" data-sort="num">Pos</th>
                        <th class="text-center" data-sort="num">Elo Change</th>
                    </tr>
                </thead>
                <tbody>
                    <% @biggest_drops.each_with_index do |rr, idx| %>
                        <tr>
                            <td class="text-center position-cell"><%= idx + 1 %></td>
                            <td class="icon-cell">
                                <%= flag_image(rr.driver, size: 24) %>
                            </td>
                            <td>
                                <%= link_to driver_path(rr.driver) do %>
                                    <%= rr.driver.forename[0] %>.<%= rr.driver.surname %>
                                <% end %>
                            </td>
                            <td class="icon-cell">
                                <% if rr.constructor&.logo_url.present? %>
                                    <img src="<%= rr.constructor.logo_url %>" alt="<%= rr.constructor.name %>" class="constructor-logo-sm" onerror="this.style.display='none'">
                                <% end %>
                            </td>
                            <td><%= link_to rr.race.circuit.name, race_path(rr.race) %></td>
                            <td><%= rr.race.year %></td>
                            <td class="text-center">P<%= rr.position_order %></td>
                            <td class="text-center text-red"><strong><%= rr.display_elo_diff.round %></strong></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>

    <%# Highest Elo Entering a Race %>
    <div class="table-header">
        <h4><i class="fa-solid fa-trophy"></i> Highest Elo Entering a Race</h4>
    </div>
    <div class="card card-flush" style="margin-bottom: 24px;">
        <div class="table-scroll-wrapper">
            <table class="current-driver-standings compact" data-controller="sortable-table">
                <thead>
                    <tr>
                        <th class="text-center" data-sort="num">#</th>
                        <th></th>
                        <th data-sort="text">Driver</th>
                        <th></th>
                        <th data-sort="text">Race</th>
                        <th data-sort="num">Year</th>
                        <th class="text-center" data-sort="num">Entering Elo</th>
                    </tr>
                </thead>
                <tbody>
                    <% @highest_entering.each_with_index do |rr, idx| %>
                        <tr class="<%= 'podium-row podium-p' + (idx + 1).to_s if idx < 3 %>">
                            <td class="text-center position-cell"><%= idx + 1 %></td>
                            <td class="icon-cell">
                                <%= flag_image(rr.driver, size: 24) %>
                            </td>
                            <td>
                                <%= link_to driver_path(rr.driver) do %>
                                    <%= rr.driver.forename[0] %>.<%= rr.driver.surname %>
                                <% end %>
                            </td>
                            <td class="icon-cell">
                                <% if rr.constructor&.logo_url.present? %>
                                    <img src="<%= rr.constructor.logo_url %>" alt="<%= rr.constructor.name %>" class="constructor-logo-sm" onerror="this.style.display='none'">
                                <% end %>
                            </td>
                            <td><%= link_to rr.race.circuit.name, race_path(rr.race) %></td>
                            <td><%= rr.race.year %></td>
                            <td class="text-center"><strong><%= elo_link(rr.display_old_elo) %></strong></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>

    <%# Fastest Rising Careers %>
    <div class="table-header">
        <h4><i class="fa-solid fa-rocket"></i> Fastest Rising Careers (First 20 Races)</h4>
    </div>
    <div class="card card-flush">
        <div class="table-scroll-wrapper">
            <table class="current-driver-standings compact" data-controller="sortable-table">
                <thead>
                    <tr>
                        <th class="text-center" data-sort="num">#</th>
                        <th></th>
                        <th data-sort="text">Driver</th>
                        <th class="text-center" data-sort="num">Start Elo</th>
                        <th class="text-center" data-sort="num">After 20 Races</th>
                        <th class="text-center" data-sort="num">Elo Gain</th>
                    </tr>
                </thead>
                <tbody>
                    <% @fastest_risers.each_with_index do |entry, idx| %>
                        <tr class="<%= 'podium-row podium-p' + (idx + 1).to_s if idx < 3 %>">
                            <td class="text-center position-cell"><%= idx + 1 %></td>
                            <td class="icon-cell">
                                <%= flag_image(entry[:driver], size: 24) %>
                            </td>
                            <td>
                                <%= link_to driver_path(entry[:driver]) do %>
                                    <%= entry[:driver].forename[0] %>.<%= entry[:driver].surname %>
                                <% end %>
                            </td>
                            <td class="text-center"><%= entry[:start_elo] %></td>
                            <td class="text-center"><%= entry[:end_elo] %></td>
                            <td class="text-center text-green"><strong>+<%= entry[:rise] %></strong></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>
</div>
