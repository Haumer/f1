<div class="devise-container">
    <div class="devise-card">
        <div class="devise-header">
            <h2>Set New Password</h2>
        </div>

        <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :put }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>
            <%= f.hidden_field :reset_password_token %>

            <div class="devise-form">
                <div class="devise-field">
                    <label for="user_password">New password</label>
                    <%= f.password_field :password, autofocus: true, autocomplete: "new-password", placeholder: "Min. #{@minimum_password_length} characters", class: "devise-input" %>
                    <span class="devise-hint"><%= @minimum_password_length %> characters minimum</span>
                </div>

                <div class="devise-actions">
                    <%= f.submit "Change Password", class: "devise-btn devise-btn-primary" %>
                </div>
            </div>
        <% end %>

        <div class="devise-links">
            <%= link_to "Back to sign in", new_session_path(resource_name) %>
        </div>
    </div>
</div>
