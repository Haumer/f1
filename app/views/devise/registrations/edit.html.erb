<div class="devise-container">
    <div class="devise-card">
        <div class="devise-header">
            <h2>Edit Account</h2>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name), html: { method: :put }) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="devise-form">
                <div class="devise-field" data-controller="username-check" data-username-check-url-value="<%= users_username_available_path %>">
                    <label for="user_username">Username</label>
                    <%= f.text_field :username, autocomplete: "username", class: "devise-input", data: { username_check_target: "input", action: "input->username-check#check" } %>
                    <span class="devise-username-status" data-username-check-target="status"></span>
                </div>

                <div class="devise-field">
                    <label for="user_email">Email</label>
                    <%= f.email_field :email, class: "devise-input" %>
                    <% if devise_mapping.confirmable? && resource.pending_reconfirmation? %>
                        <span class="devise-hint">Currently waiting confirmation for: <%= resource.unconfirmed_email %></span>
                    <% end %>
                </div>

                <div class="devise-field">
                    <label for="user_password">New password</label>
                    <%= f.password_field :password, autocomplete: "new-password", placeholder: "Leave blank to keep current", class: "devise-input" %>
                </div>

                <div class="devise-field">
                    <label for="user_current_password">Current password <span class="devise-required">*</span></label>
                    <%= f.password_field :current_password, autocomplete: "current-password", placeholder: "Required to save changes", class: "devise-input" %>
                </div>

                <div class="devise-actions">
                    <%= f.submit "Update", class: "devise-btn devise-btn-primary" %>
                </div>
            </div>
        <% end %>

        <div class="devise-danger-zone">
            <h3>Delete Account</h3>
            <p>This action is permanent and cannot be undone.</p>
            <%= button_to "Delete my account", registration_path(resource_name), method: :delete, data: { turbo_confirm: "Are you sure? This will permanently delete your account." }, class: "devise-btn devise-btn-danger" %>
        </div>

        <div class="devise-links">
            <%= link_to "Back", :back %>
        </div>
    </div>
</div>
