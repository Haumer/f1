<div class="devise-container">
    <div class="devise-card">
        <div class="devise-header">
            <h2>Create Account</h2>
            <p class="devise-subtitle">Join the F1 Elo community</p>
        </div>

        <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
            <%= render "devise/shared/error_messages", resource: resource %>

            <div class="devise-form">
                <div class="devise-field" data-controller="username-check" data-username-check-url-value="<%= users_username_available_path %>">
                    <label for="user_username">Username</label>
                    <%= f.text_field :username, autofocus: true, autocomplete: "username", placeholder: "your-username", class: "devise-input", data: { username_check_target: "input", action: "input->username-check#check" } %>
                    <span class="devise-username-status" data-username-check-target="status"></span>
                    <span class="devise-hint">3-24 characters. Letters, numbers, hyphens, underscores.</span>
                </div>

                <div class="devise-field">
                    <label for="user_email">Email</label>
                    <%= f.email_field :email, autocomplete: "email", placeholder: "you@example.com", class: "devise-input", value: resource.email.presence || params[:email] %>
                </div>

                <div class="devise-field">
                    <label for="user_password">Password</label>
                    <%= f.password_field :password, autocomplete: "new-password", placeholder: "Min. #{@minimum_password_length} characters", class: "devise-input" %>
                    <span class="devise-hint"><%= @minimum_password_length %> characters minimum</span>
                </div>

                <div class="devise-actions">
                    <%= f.submit "Create Account", class: "devise-btn devise-btn-primary" %>
                </div>
            </div>
        <% end %>

        <div class="devise-links">
            <%= link_to "Already have an account? Sign in", new_session_path(resource_name) %>
        </div>
    </div>
</div>
