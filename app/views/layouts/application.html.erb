<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for?(:title) ? "#{yield(:title)} — F1 Elo" : "F1 Elo — Rating Every F1 Driver Since 1950" %></title>
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <meta name="theme-color" content="#0a0a0f">
    <meta name="description" content="<%= content_for?(:description) ? yield(:description) : "Elo ratings for every Formula 1 driver since 1950. Compare drivers across eras, track constructor performance, and play Fantasy F1." %>">

    <%# PWA %>
    <link rel="manifest" href="/manifest.webmanifest">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="F1 Elo">

    <%# Favicon %>
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <link rel="icon" href="/favicon.ico" sizes="32x32">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png">

    <%# Open Graph %>
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="F1 Elo">
    <meta property="og:title" content="<%= content_for?(:title) ? yield(:title) : "F1 Elo — Rating Every F1 Driver Since 1950" %>">
    <meta property="og:description" content="<%= content_for?(:description) ? yield(:description) : "Elo ratings for every Formula 1 driver since 1950. Compare drivers across eras, track constructor performance, and play Fantasy F1." %>">
    <meta property="og:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "#{request.base_url}/og-image.png" %>">
    <meta property="og:url" content="<%= request.original_url %>">

    <%# Twitter Card %>
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:site" content="@f1elo">
    <meta name="twitter:title" content="<%= content_for?(:title) ? yield(:title) : "F1 Elo" %>">
    <meta name="twitter:description" content="<%= content_for?(:description) ? yield(:description) : "Elo ratings for every Formula 1 driver since 1950." %>">
    <meta name="twitter:image" content="<%= content_for?(:og_image) ? yield(:og_image) : "#{request.base_url}/og-image.png" %>">

    <%# Google Analytics %>
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-BELSL6SC6F"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-BELSL6SC6F');
    </script>

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <script>
      document.addEventListener('turbo:before-visit', () => {
        document.querySelector('.navbar .links')?.classList.remove('open');
      });
      if ('serviceWorker' in navigator) {
        navigator.serviceWorker.register('/sw.js');
      }
    </script>
  </head>

  <body<%= " style=\"--page-accent: #{@page_accent}; --page-accent-rgb: #{hex_to_rgb(@page_accent)};\"".html_safe if @page_accent %>>
    <% if notice.present? %>
      <div class="flash flash-notice" data-controller="flash">
        <span><%= notice %></span>
        <button class="flash-dismiss" data-action="click->flash#dismiss">&times;</button>
      </div>
    <% end %>
    <% if alert.present? %>
      <div class="flash flash-alert" data-controller="flash">
        <span><%= alert %></span>
        <button class="flash-dismiss" data-action="click->flash#dismiss">&times;</button>
      </div>
    <% end %>
    <div class="container py-3">
      <%= render 'components/navbar' %>
      <main><%= yield %></main>
    </div>
    <footer class="site-footer">
      <div class="site-footer-inner">
        <div class="footer-brand">
          <span class="font-display footer-logo">F1 ELO</span>
          <span class="footer-tagline">Rating every Formula 1 driver since 1950</span>
        </div>
        <div class="footer-links-grid">
          <div class="footer-col">
            <span class="footer-col-title">Drivers</span>
            <%= link_to "Peak Elo", peak_elo_drivers_path %>
            <%= link_to "Active Elo", current_active_elo_drivers_path %>
            <%= link_to "Compare", compare_drivers_path %>
          </div>
          <div class="footer-col">
            <span class="footer-col-title">Racing</span>
            <%= link_to "Seasons", seasons_path %>
            <%= link_to "Circuits", circuits_path %>
            <%= link_to "Constructors", constructors_path %>
          </div>
          <div class="footer-col">
            <span class="footer-col-title">Stats</span>
            <%= link_to "Elo Milestones", elo_milestones_path %>
            <%= link_to "Badges", badges_path %>
            <%= link_to "How Elo Works", elo_path %>
            <%= link_to "About", about_path %>
            <%= link_to "Terms", terms_path %>
          </div>
        </div>
      </div>
      <div class="footer-bottom">
        <span class="footer-copy">Not affiliated with Formula 1, FIA, or any team. All trademarks belong to their respective owners.</span>
      </div>
    </footer>
  </body>
</html>
