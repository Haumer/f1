<% content_for(:title) { "Race Preview — #{@race.circuit.name} #{@race.season.year}" } %>
<% content_for(:description) { "AI-powered race preview for #{@race.circuit.name} #{@race.season.year} — predictions, form guide, and key battles." } %>
<div class="homepage-container">
    <div class="page-hero race-hero">
        <div class="page-hero-bg"></div>
        <div class="page-hero-content">
            <span class="page-hero-label">
                <%= link_to race_path(@race), class: "page-hero-link" do %>
                    <i class="fa-solid fa-chevron-left"></i> Round <%= @race.round %> · <%= @race.year %>
                <% end %>
            </span>
            <h1 class="page-hero-title"><i class="fa-solid fa-robot"></i> Race Preview</h1>
            <p class="page-hero-meta">
                <%= @race.circuit.name %> · <%= @race.circuit.location %>, <%= @race.circuit.country %>
                · <%= @race.date.strftime("%B %d, %Y") %>
            </p>
        </div>
    </div>

    <% if @analysis.picks.present? %>
        <div class="ai-picks-strip">
            <% if @analysis.picks["winner"] %>
                <div class="ai-pick">
                    <span class="ai-pick-label">Winner</span>
                    <span class="ai-pick-value"><%= @analysis.picks["winner"] %></span>
                </div>
            <% end %>
            <% if @analysis.picks["dark_horse"] %>
                <div class="ai-pick">
                    <span class="ai-pick-label">Dark Horse</span>
                    <span class="ai-pick-value"><%= @analysis.picks["dark_horse"] %></span>
                </div>
            <% end %>
            <% if @analysis.picks["fastest_lap"] %>
                <div class="ai-pick">
                    <span class="ai-pick-label">Fastest Lap</span>
                    <span class="ai-pick-value"><%= @analysis.picks["fastest_lap"] %></span>
                </div>
            <% end %>
            <% if @analysis.picks["dnf_risk"] %>
                <div class="ai-pick">
                    <span class="ai-pick-label">DNF Risk</span>
                    <span class="ai-pick-value"><%= @analysis.picks["dnf_risk"] %></span>
                </div>
            <% end %>
        </div>

        <% if @analysis.picks["podium"] %>
            <div class="ai-podium-strip">
                <% @analysis.picks["podium"].each_with_index do |driver, i| %>
                    <div class="ai-podium-item">
                        <span class="ai-podium-pos place-<%= i + 1 %>">P<%= i + 1 %></span>
                        <span class="ai-podium-driver"><%= driver %></span>
                    </div>
                <% end %>
            </div>
        <% end %>

        <% if @analysis.picks["top5"] %>
            <div class="card card-flush">
                <div class="table-header">
                    <h3>Predicted Top 5</h3>
                </div>
                <table class="race-results">
                    <tbody>
                        <% @analysis.picks["top5"].each_with_index do |driver, i| %>
                            <tr>
                                <td class="text-center col-pos"><%= i + 1 %></td>
                                <td class="col-name"><%= driver %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        <% end %>
    <% end %>

    <div class="card ai-analysis-card">
        <div class="ai-analysis-header">
            <div class="ai-analysis-title">
                <i class="fa-solid fa-robot"></i>
                <h4>Full Analysis</h4>
            </div>
            <span class="ai-analysis-meta">
                Generated <%= time_ago_in_words(@analysis.generated_at) %> ago
            </span>
        </div>

        <div class="ai-analysis-content">
            <div class="ai-analysis-body">
                <%= simple_format(@analysis.content) %>
            </div>
        </div>

        <% if @analysis.sources.present? %>
            <div class="ai-analysis-sources">
                <span class="ai-sources-label">Sources:</span>
                <% @analysis.sources.each do |source| %>
                    <% if source["url"].present? %>
                        <%= link_to source["title"], source["url"], target: "_blank", rel: "noopener", class: "ai-source-link" %>
                    <% else %>
                        <span class="ai-source-link ai-source-no-link"><%= source["title"] %></span>
                    <% end %>
                <% end %>
            </div>
        <% end %>
    </div>

    <span class="data-source">Analysis generated by Claude (Anthropic). Predictions are for entertainment purposes only.</span>
</div>
