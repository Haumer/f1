<% content_for(:title) { "Rating Every F1 Driver Since 1950" } %>
<% content_for(:description) { "Elo ratings for every Formula 1 driver since 1950. Compare drivers across eras, track constructor performance, and play Fantasy F1." } %>
<div class="homepage-container">
    <% if @season %>
        <%# 1. Contextual Hero %>
        <% case @homepage_phase %>
        <% when :season_start %>
            <%= render "pages/hero_season_start" %>
        <% when :season_complete %>
            <%= render "pages/hero_season_complete" %>
        <% when :post_race %>
            <%= render "pages/hero_post_race" %>
        <% when :race_complete %>
            <%= render "pages/hero_race_complete" %>
        <% when :race_day %>
            <%= render "pages/hero_race_day" %>
        <% when :race_weekend %>
            <%= render "pages/hero_race_weekend" %>
        <% when :pre_race %>
            <%= render "pages/hero_pre_race" %>
        <% end %>

        <%# 2. Persistent Latest Result Strip (skip during post_race — hero already shows it) %>
        <% if @latest_race&.has_results? && @homepage_phase != :post_race %>
            <%= render "pages/latest_result_strip", race: @latest_race, podium: @podium_results %>
        <% end %>

        <%# 3. Next Race strip (always visible when available, skip if hero already covers it) %>
        <% unless [:race_weekend, :race_day, :race_complete, :pre_race, :season_start].include?(@homepage_phase) %>
            <% if @next_race && @next_race.date > @today %>
                <div class="next-race-strip">
                    <i class="fa-solid fa-calendar"></i>
                    <span class="next-race-strip-label">Next Race</span>
                    <span class="next-race-strip-name"><%= link_to @next_race.circuit.name, race_path(@next_race) %></span>
                    <span class="next-race-strip-meta">
                        Round <%= @next_race.round %> · <%= @next_race.date.strftime("%b %d") %><% if @next_race.starts_at %> · <%= @next_race.starts_at.strftime("%H:%M UTC") %><% end %>
                    </span>
                    <span class="next-race-strip-countdown">in <%= (@next_race.date - @today).to_i %> days</span>
                    <%= link_to calendar_races_path, class: "next-race-strip-link" do %>
                        Full Race Calendar <i class="fa-solid fa-arrow-right"></i>
                    <% end %>
                </div>
            <% end %>
        <% end %>

        <%# 4. Driver Standings %>
        <% if @season_drivers&.any? %>
            <div class="table-header">
                <%= link_to season_path(@season), class: "table-header-link" do %>
                    <h3><%= @season.year %> Driver Standings <i class="fa-solid fa-arrow-right"></i></h3>
                <% end %>
            </div>
            <div class="card card-flush">
                <div class="table-scroll-wrapper">
                    <div data-controller="expandable-table" data-expandable-table-limit-value="10">
                        <%= render 'drivers/grid_table', season_drivers: @season_drivers, grid_standings: @grid_standings, standings_extras: (@standings_season == @season ? @standings_extras : {}) %>
                        <% if @season_drivers.size > 10 %>
                            <button class="expand-table-btn" data-action="expandable-table#toggle" data-expandable-table-target="button">
                                Show all <%= @season_drivers.size %> drivers
                            </button>
                        <% end %>
                    </div>
                </div>
            </div>
        <% end %>

        <%# 5. Previous Season Recap %>
        <% if @standings_season && @standings_season != @season %>
            <div class="table-header">
                <%= link_to season_path(@standings_season), class: "table-header-link" do %>
                    <h3><%= @standings_season.year %> Season <i class="fa-solid fa-arrow-right"></i></h3>
                <% end %>
            </div>

            <% top3 = @standings_season.latest_driver_standings&.first(3) %>
            <% if top3&.any? %>
                <div class="card last-race-card">
                    <div class="last-race-header">
                        <h4>Drivers</h4>
                    </div>
                    <div class="podium-display">
                        <% top3.each do |ds| %>
                            <% constructor = @recap_constructors[ds.driver_id] %>
                            <div class="podium-item podium-p<%= ds.position %>"
                                 style="--constructor-color: <%= constructor_color(constructor) %>">
                                <span class="podium-position place-<%= ds.position %>">P<%= ds.position %></span>
                                <span class="podium-driver"><%= link_to "#{ds.driver.forename&.first}.#{ds.driver.surname}", driver_path(ds.driver) %></span>
                                <span class="stat-detail"><%= ds.points&.round %> pts · <%= ds.wins || 0 %> wins</span>
                                <%= constructor_logo_or_name(constructor) %>
                            </div>
                        <% end %>
                    </div>
                </div>
            <% end %>

            <% if @constructor_top3&.any? %>
                <div class="card last-race-card">
                    <div class="last-race-header">
                        <h4>Constructors</h4>
                    </div>
                    <div class="podium-display">
                        <% @constructor_top3.each_with_index do |entry, idx| %>
                            <% pos = idx + 1 %>
                            <% constructor = entry[:constructor] %>
                            <% color = constructor_color(constructor) %>
                            <div class="podium-item podium-p<%= pos %>"
                                 style="--constructor-color: <%= color %>">
                                <span class="podium-position place-<%= pos %>">P<%= pos %></span>
                                <span class="podium-driver">
                                    <%= link_to constructor.name, constructor_path(constructor) %>
                                </span>
                                <span class="stat-detail"><%= entry[:points]&.round %> pts · <%= entry[:wins] %> wins</span>
                                <%= constructor_logo_or_name(constructor) %>
                            </div>
                        <% end %>
                    </div>
                </div>
            <% end %>
        <% end %>

        <%# 5b. Race Picks CTA %>
        <% if @next_race && current_user %>
            <% user_pick = RacePick.find_by(user: current_user, race: @next_race) %>
            <div class="picks-cta">
                <div class="picks-cta-text">
                    <i class="fa-solid fa-hand-pointer"></i>
                    <% if user_pick&.picks&.any? %>
                        <span>You've placed <strong><%= user_pick.manual_picks.size %> picks</strong> for <%= @next_race.circuit.name %></span>
                    <% else %>
                        <span>Make your <strong>race picks</strong> for <%= @next_race.circuit.name %></span>
                    <% end %>
                </div>
                <%= link_to edit_race_picks_path, class: "picks-cta-link" do %>
                    <%= user_pick&.picks&.any? ? "Edit Picks" : "Make Picks" %> <i class="fa-solid fa-arrow-right"></i>
                <% end %>
            </div>
        <% end %>

        <%# 6. Fantasy section %>
        <% if current_user && @fantasy_portfolio %>
            <div class="table-header">
                <%= link_to fantasy_overview_path(@fantasy_portfolio.user.username), class: "table-header-link" do %>
                    <h3>Fantasy F1 <i class="fa-solid fa-arrow-right"></i></h3>
                <% end %>
            </div>
            <%= render "fantasy_portfolios/portfolio_card",
                       portfolio: @fantasy_portfolio,
                       stock_portfolio: @fantasy_stock_portfolio,
                       support: @fantasy_support,
                       rank: @fantasy_rank %>
        <% elsif current_user %>
            <div class="table-header">
                <h3>Fantasy F1</h3>
            </div>
            <div class="fantasy-cta-card">
                <div class="fantasy-cta-content">
                    <i class="fa-solid fa-chess-knight"></i>
                    <div>
                        <p>Trade driver shares based on Elo performance — go long on your favorites, short the rest, and compete on the leaderboard.</p>
                    </div>
                </div>
                <%= link_to new_fantasy_portfolio_path, class: "fantasy-btn fantasy-btn-primary" do %>
                    <i class="fa-solid fa-plus"></i> Start Trading
                <% end %>
            </div>
        <% else %>
            <div class="table-header">
                <h3>Fantasy F1</h3>
            </div>
            <div class="fantasy-cta-card">
                <div class="fantasy-cta-content">
                    <i class="fa-solid fa-chess-knight"></i>
                    <div>
                        <p>Sign up to trade driver shares based on Elo, compete against other fans, and climb the leaderboard.</p>
                    </div>
                </div>
                <%= link_to new_user_registration_path, class: "fantasy-btn fantasy-btn-primary" do %>
                    <i class="fa-solid fa-user-plus"></i> Join Fantasy League
                <% end %>
            </div>
        <% end %>

        <%# 8. Leaderboard Preview %>
        <% if @leaderboard_preview&.any? %>
            <div class="card leaderboard-preview-card">
                <div class="leaderboard-preview-header">
                    <h4><i class="fa-solid fa-ranking-star"></i> Fantasy Leaderboard</h4>
                    <%= link_to combined_leaderboard_path, class: "last-race-link" do %>
                        Full Leaderboard <i class="fa-solid fa-arrow-right"></i>
                    <% end %>
                </div>
                <div class="leaderboard-preview-list">
                    <% @leaderboard_preview.each do |entry| %>
                        <div class="leaderboard-preview-row">
                            <span class="leaderboard-preview-rank place-<%= entry[:rank] %>">#<%= entry[:rank] %></span>
                            <span class="leaderboard-preview-name"><%= entry[:user].username %></span>
                            <span class="leaderboard-preview-net <%= entry[:net] >= 0 ? 'text-green' : 'text-red' %>">
                                <%= entry[:net] >= 0 ? '+' : '' %><%= number_with_delimiter(entry[:net].round(0)) %>
                            </span>
                        </div>
                    <% end %>
                </div>
            </div>
        <% end %>

        <%# 9. Explore Grid (always visible) %>
        <div class="explore-archive">
            <div class="explore-header">Explore</div>
            <div class="explore-grid">
                <%= link_to peak_elo_drivers_path, class: "card explore-card" do %>
                    <div class="explore-icon"><i class="fa-solid fa-ranking-star"></i></div>
                    <div class="explore-info">
                        <span class="explore-name">Peak Elo</span>
                        <span class="explore-desc">All-time highest ratings</span>
                    </div>
                <% end %>
                <%= link_to compare_drivers_path, class: "card explore-card" do %>
                    <div class="explore-icon"><i class="fa-solid fa-code-compare"></i></div>
                    <div class="explore-info">
                        <span class="explore-name">Compare Drivers</span>
                        <span class="explore-desc">Head-to-head Elo history</span>
                    </div>
                <% end %>
                <%= link_to seasons_path, class: "card explore-card" do %>
                    <div class="explore-icon"><i class="fa-solid fa-calendar"></i></div>
                    <div class="explore-info">
                        <span class="explore-name">All Seasons</span>
                        <span class="explore-desc">Browse every F1 season</span>
                    </div>
                <% end %>
                <%= link_to circuits_path, class: "card explore-card" do %>
                    <div class="explore-icon"><i class="fa-solid fa-location-dot"></i></div>
                    <div class="explore-info">
                        <span class="explore-name">Circuits</span>
                        <span class="explore-desc">Tracks around the world</span>
                    </div>
                <% end %>
                <%= link_to constructors_path, class: "card explore-card" do %>
                    <div class="explore-icon"><i class="fa-solid fa-warehouse"></i></div>
                    <div class="explore-info">
                        <span class="explore-name">Constructors</span>
                        <span class="explore-desc">Team histories & Elo</span>
                    </div>
                <% end %>
                <%= link_to podiums_races_path, class: "card explore-card" do %>
                    <div class="explore-icon"><i class="fa-solid fa-medal"></i></div>
                    <div class="explore-info">
                        <span class="explore-name">Podium Leaders</span>
                        <span class="explore-desc">Most podiums all-time</span>
                    </div>
                <% end %>
            </div>
        </div>
    <% else %>
        <div class="empty-state">
            <i class="fa-solid fa-flag-checkered"></i>
            <h3>No season data yet</h3>
            <p>Import F1 season data to see championship standings and Elo ratings.</p>
        </div>
    <% end %>
</div>
