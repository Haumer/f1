<div class="page-hero pre-race-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-content">
        <span class="page-hero-label">
            <i class="fa-solid fa-calendar"></i>
            Race Week · <%= @countdown_race.date.strftime("%B %d") %>
        </span>
        <h1 class="page-hero-title"><%= link_to @countdown_race.circuit.name, race_path(@countdown_race) %></h1>
        <p class="page-hero-meta">Round <%= @countdown_race.round %> · <%= @countdown_race.circuit.location %>, <%= @countdown_race.circuit.country %></p>

        <% if @next_session %>
            <div class="countdown-timer"
                 data-controller="countdown"
                 data-countdown-target-value="<%= @next_session[:starts_at].iso8601 %>"
                 data-countdown-label-value="<%= @next_session[:name] %> in">
            </div>
        <% else %>
            <div class="countdown-badge">
                <span class="countdown-number"><%= @days_until_fp1 %></span>
                <span class="countdown-label"><%= @days_until_fp1 == 1 ? 'day' : 'days' %> until FP1</span>
            </div>
        <% end %>

        <% if @countdown_race.starts_at %>
            <div class="race-time-preview">
                <span class="race-time-label">Race Start</span>
                <span class="race-time-value"><%= @countdown_race.starts_at.strftime("%H:%M UTC") %></span>
            </div>
        <% end %>
    </div>
</div>

<%= render "shared/circuit_kings", circuit_kings: @circuit_kings %>
