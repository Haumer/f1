<% content_for(:title) { "How Fantasy Works" } %>
<% content_for(:description) { "Learn how Fantasy F1 works — trade driver shares, earn dividends, and compete on the leaderboard." } %>
<div class="homepage-container">
    <div class="table-header"><h3>How Fantasy Works</h3></div>

    <div class="elo-explanation">
        <p>
            Fantasy F1 is a stock market for F1 drivers. Buy and sell driver shares based on
            their Elo rating performance, earn dividends from top finishes, and compete against other
            players on the leaderboard.
        </p>

        <%# ═══ HOW IT WORKS ═══ %>
        <div class="table-header"><h3>Getting Started</h3></div>

        <div class="elo-worked-example">
            <div class="elo-step-grid">
                <div class="elo-step">
                    <div class="elo-step-pip" style="background: var(--page-accent, #e10600)">1</div>
                    <div class="elo-step-content">
                        <strong>Starting Capital</strong>
                        <span>You receive <%= number_with_delimiter(Fantasy::CreatePortfolio::STARTING_CAPITAL.to_i) %> fantasy cash. This is your budget.</span>
                    </div>
                </div>
                <div class="elo-step">
                    <div class="elo-step-pip" style="background: var(--page-accent, #e10600)">2</div>
                    <div class="elo-step-content">
                        <strong>Buy Shares</strong>
                        <span>Head to the Market and buy shares of drivers you believe in. Prices are based on Elo &divide; <%= FantasyStockPortfolio::PRICE_DIVISOR.to_i %>, adjusted by market demand.</span>
                    </div>
                </div>
                <div class="elo-step">
                    <div class="elo-step-pip" style="background: var(--page-accent, #e10600)">3</div>
                    <div class="elo-step-content">
                        <strong>Race Weekend</strong>
                        <span>The market closes 1 minute before race start. After the race, driver Elos update, dividends are paid, and your portfolio value changes.</span>
                    </div>
                </div>
                <div class="elo-step">
                    <div class="elo-step-pip" style="background: var(--page-accent, #e10600)">4</div>
                    <div class="elo-step-content">
                        <strong>Trade &amp; Compete</strong>
                        <span>Sell shares to lock in profits, open new positions, and climb the leaderboard. Up to <%= FantasyStockPortfolio::MAX_POSITIONS %> positions at a time.</span>
                    </div>
                </div>
            </div>
        </div>

        <%# ═══ LONG & SHORT ═══ %>
        <div class="table-header"><h3>Long &amp; Short Positions</h3></div>

        <div class="elo-worked-example">
            <div class="elo-step-grid">
                <div class="elo-step">
                    <div class="elo-step-pip" style="background: #52c41a">L</div>
                    <div class="elo-step-content">
                        <strong>Long Positions</strong>
                        <span>Buy shares and profit when a driver's Elo rises. Long positions earn <strong>dividends</strong> for each top-10 finish, scaled by constructor strength (underdogs pay more).</span>
                    </div>
                </div>
                <div class="elo-step">
                    <div class="elo-step-pip" style="background: #e10600">S</div>
                    <div class="elo-step-content">
                        <strong>Short Positions</strong>
                        <span>Bet against a driver. You profit when their Elo drops. Shorts require collateral (locked cash) and incur a <%= (Fantasy::Stock::SettleRace::BORROW_FEE_RATE * 100).round(2) %>% per-race borrow fee. Auto-liquidated if losses reach 2&times; entry price.</span>
                    </div>
                </div>
            </div>
        </div>

        <%# ═══ EARNING CASH ═══ %>
        <div class="table-header"><h3>Earning Fantasy Cash</h3></div>

        <div class="elo-results-grid elo-results-grid-3">
            <div class="elo-result-card">
                <div class="elo-result-label">Starting Capital</div>
                <div class="elo-result-value"><%= number_with_delimiter(Fantasy::CreatePortfolio::STARTING_CAPITAL.to_i) %></div>
                <span class="elo-result-sub">Awarded once when you create a portfolio</span>
            </div>
            <div class="elo-result-card">
                <div class="elo-result-label">Dividends</div>
                <div class="elo-result-value"><%= Fantasy::Stock::SettleRace::DIVIDEND_BASE %> &times; constructor</div>
                <span class="elo-result-sub">Top-10 finishes pay dividends + surprise bonus for overperformance</span>
            </div>
            <div class="elo-result-card">
                <div class="elo-result-label">Selling Shares</div>
                <div class="elo-result-value">Buy Low, Sell High</div>
                <span class="elo-result-sub">Sell long positions when a driver's Elo has risen</span>
            </div>
            <div class="elo-result-card">
                <div class="elo-result-label">Short Profits</div>
                <div class="elo-result-value">Entry &minus; Current</div>
                <span class="elo-result-sub">Profit when a shorted driver's Elo drops</span>
            </div>
            <div class="elo-result-card">
                <div class="elo-result-label">Team Allegiance</div>
                <div class="elo-result-value"><i class="fa-solid fa-shield-halved"></i></div>
                <span class="elo-result-sub">Pick a team to support &mdash; shown on leaderboards</span>
            </div>
        </div>

        <%# ═══ LEADERBOARD ═══ %>
        <div class="table-header"><h3>Leaderboard</h3></div>
        <p>
            The leaderboard ranks players by <strong>Net P&amp;L</strong> &mdash; the profit or loss
            generated from your starting capital. Everyone starts with the same capital, so whoever
            generates the most value wins.
        </p>

        <%# ═══ ACHIEVEMENTS ═══ %>
        <div class="table-header"><h3>Achievements</h3></div>
        <p>
            Earn achievements by hitting milestones in your portfolio. There are three tiers:
            <span style="color: #cd7f32;">Bronze</span>,
            <span style="color: #c0c0c0;">Silver</span>, and
            <span style="color: #ffd700;">Gold</span>.
            Achievements are checked automatically after each race.
        </p>
    </div>

    <%# Get Started %>
    <div class="about-card card">
        <div class="about-card-header">
            <span class="about-card-icon"><i class="fa-solid fa-rocket"></i></span>
            <h3>Ready to Play?</h3>
        </div>
        <div class="about-card-body">
            <div class="about-links-row">
                <% if user_signed_in? %>
                    <% portfolio = current_user.fantasy_portfolio_for(Season.sorted_by_year.first) %>
                    <% if portfolio %>
                        <%= link_to fantasy_overview_path(current_user.username), class: "about-link about-link-primary" do %>
                            <i class="fa-solid fa-briefcase"></i> My Portfolio
                        <% end %>
                    <% else %>
                        <%= link_to new_fantasy_portfolio_path, class: "about-link about-link-primary" do %>
                            <i class="fa-solid fa-plus"></i> Start Trading
                        <% end %>
                    <% end %>
                <% else %>
                    <%= link_to new_user_session_path, class: "about-link about-link-primary" do %>
                        <i class="fa-solid fa-right-to-bracket"></i> Sign In to Play
                    <% end %>
                <% end %>
                <%= link_to combined_leaderboard_path, class: "about-link" do %>
                    <i class="fa-solid fa-ranking-star"></i> Leaderboard
                <% end %>
            </div>
        </div>
    </div>
</div>
