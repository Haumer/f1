<% v2 = Setting.use_elo_v2? %>
<% peak_col = v2 ? :peak_elo_v2 : :peak_elo %>
<% thresholds = v2 ? [2600, 2450, 2300, 2100] : [1500, 1400, 1300, 1200] %>

<div class="homepage-container">
    <div class="page-hero page-hero-compact">
        <div class="page-hero-bg"></div>
        <div class="page-hero-content">
            <h1 class="page-hero-title">How Elo Works</h1>
            <p class="page-hero-meta">Understanding the rating system behind F1 Elo</p>
        </div>
    </div>

    <div class="card about-section">
        <h4>What is Elo?</h4>
        <p>
            The Elo rating system, originally developed for chess by Arpad Elo, is a method for calculating
            the relative skill of players. Every driver starts at a rating of <strong><%= v2 ? 2000 : 1000 %></strong>. After each race,
            ratings are adjusted based on finishing position — beating a higher-rated driver gains you more points
            than beating a lower-rated one.
        </p>

        <h4>How It Works in F1</h4>
        <p>
            Each race is treated as a series of head-to-head matchups between every pair of drivers. For each pairing:
        </p>
        <ul>
            <li>The driver who finishes ahead "wins" the matchup</li>
            <li>An <strong>expected score</strong> is calculated based on the rating difference:
                <code>E = 1 / (1 + 10^((opponent_rating - player_rating) / <%= v2 ? EloRatingV2::SCALE.to_i : 400 %>))</code></li>
            <li>The rating adjustment is: <code>K × (actual_score - expected_score)</code></li>
            <% if v2 %>
                <li>Base K-factor is <strong><%= EloRatingV2::BASE_K %></strong>, scaled by season length (<%= EloRatingV2::REFERENCE_RACES %> reference races) and normalized by <strong>√(grid size − 1)</strong></li>
                <li>At each season's end, ratings regress <strong><%= (EloRatingV2::REGRESSION_FACTOR * 100).round(0) %>%</strong> toward the starting Elo of <%= EloRatingV2::STARTING_ELO.to_i %></li>
            <% else %>
                <li>K-factor is set to <strong>2</strong> per matchup, which keeps ratings stable while still responsive</li>
            <% end %>
        </ul>
        <p>
            A driver's total rating change for a race is the sum of adjustments across all opponents.
            With 20 drivers on the grid, that's 19 head-to-head matchups per race.
        </p>

        <h4>Why Elo for F1?</h4>
        <p>
            Unlike championship points, Elo ratings account for the <strong>strength of the field</strong>.
            Winning against a grid of highly-rated drivers is worth more than winning against weaker competition.
            This makes it possible to compare drivers across different eras — a <%= thresholds[0] %>-rated driver in 1955 demonstrated
            the same level of dominance as a <%= thresholds[0] %>-rated driver in 2024.
        </p>
        <p>
            Across <strong><%= @total_races %></strong> races and <strong><%= @total_drivers %></strong> drivers
            in F1 history, the Elo system produces a natural distribution of skill tiers.
        </p>
    </div>

    <div class="table-header" id="tiers">
        <div class="table-header-title">
            <h3>Elo Tiers</h3>
            <a href="#tiers" class="anchor-copy" data-controller="copy-anchor" data-action="click->copy-anchor#copy" title="Copy link to section"><i class="fa-solid fa-link"></i></a>
        </div>
    </div>

    <div class="elo-tiers-grid">
        <div class="elo-tier-card tier-elite">
            <div class="tier-header">
                <span class="elo-tier-badge elo-tier-elite">Elite</span>
                <span class="tier-range"><%= thresholds[0] %>+</span>
            </div>
            <p class="tier-description">
                The all-time greats. Drivers who achieved sustained dominance against the strongest competition.
                Only <strong><%= @tier_counts[:elite] %></strong> drivers
                (<%= (@tier_counts[:elite].to_f / @total_drivers * 100).round(1) %>%) have reached this level.
            </p>
            <div class="tier-examples">
                <% Driver.where("#{peak_col} >= ?", thresholds[0]).order(peak_col => :desc).limit(5).each do |d| %>
                    <%= link_to driver_path(d), class: "tier-driver" do %>
                        <%= d.forename[0] %>.<%= d.surname %> <span class="tier-elo"><%= d.display_peak_elo.round %></span>
                    <% end %>
                <% end %>
            </div>
        </div>

        <div class="elo-tier-card tier-world-class">
            <div class="tier-header">
                <span class="elo-tier-badge elo-tier-world-class">World Class</span>
                <span class="tier-range"><%= thresholds[1] %>–<%= thresholds[0] - 1 %></span>
            </div>
            <p class="tier-description">
                Championship contenders and race winners who consistently performed at the highest level.
                <strong><%= @tier_counts[:world_class] %></strong> drivers
                (<%= (@tier_counts[:world_class].to_f / @total_drivers * 100).round(1) %>%).
            </p>
            <div class="tier-examples">
                <% Driver.where("#{peak_col} >= ? AND #{peak_col} < ?", thresholds[1], thresholds[0]).order(peak_col => :desc).limit(5).each do |d| %>
                    <%= link_to driver_path(d), class: "tier-driver" do %>
                        <%= d.forename[0] %>.<%= d.surname %> <span class="tier-elo"><%= d.display_peak_elo.round %></span>
                    <% end %>
                <% end %>
            </div>
        </div>

        <div class="elo-tier-card tier-strong">
            <div class="tier-header">
                <span class="elo-tier-badge elo-tier-strong">Strong</span>
                <span class="tier-range"><%= thresholds[2] %>–<%= thresholds[1] - 1 %></span>
            </div>
            <p class="tier-description">
                Solid midfield performers and occasional podium finishers. Competitive drivers who proved themselves against strong fields.
                <strong><%= @tier_counts[:strong] %></strong> drivers
                (<%= (@tier_counts[:strong].to_f / @total_drivers * 100).round(1) %>%).
            </p>
            <div class="tier-examples">
                <% Driver.where("#{peak_col} >= ? AND #{peak_col} < ?", thresholds[2], thresholds[1]).order(peak_col => :desc).limit(5).each do |d| %>
                    <%= link_to driver_path(d), class: "tier-driver" do %>
                        <%= d.forename[0] %>.<%= d.surname %> <span class="tier-elo"><%= d.display_peak_elo.round %></span>
                    <% end %>
                <% end %>
            </div>
        </div>

        <div class="elo-tier-card tier-average">
            <div class="tier-header">
                <span class="elo-tier-badge elo-tier-average">Average</span>
                <span class="tier-range"><%= thresholds[3] %>–<%= thresholds[2] - 1 %></span>
            </div>
            <p class="tier-description">
                Reliable competitors who carved out respectable F1 careers without reaching the top step.
                <strong><%= @tier_counts[:average] %></strong> drivers
                (<%= (@tier_counts[:average].to_f / @total_drivers * 100).round(1) %>%).
            </p>
        </div>

        <div class="elo-tier-card tier-developing">
            <div class="tier-header">
                <span class="elo-tier-badge elo-tier-developing">Developing</span>
                <span class="tier-range">Below <%= thresholds[3] %></span>
            </div>
            <p class="tier-description">
                The largest group — short careers, backmarkers, or drivers who never had the machinery to climb higher. Many only raced a handful of grands prix.
                <strong><%= @tier_counts[:developing] %></strong> drivers
                (<%= (@tier_counts[:developing].to_f / @total_drivers * 100).round(1) %>%).
            </p>
        </div>
    </div>

    <div class="table-header" id="example" style="margin-top: 24px;">
        <div class="table-header-title">
            <h3>Worked Example</h3>
            <a href="#example" class="anchor-copy" data-controller="copy-anchor" data-action="click->copy-anchor#copy" title="Copy link to section"><i class="fa-solid fa-link"></i></a>
        </div>
    </div>

    <div class="card about-section elo-worked-example">
        <p class="elo-example-intro">
            Let's walk through a simplified 4-driver race to see exactly how the math works.
        </p>

        <%
            # Worked example data
            ex_drivers = [
                { name: "Verstappen", elo: 2650, pos: 1, color: "#3671C6" },
                { name: "Hamilton", elo: 2520, pos: 2, color: "#27F4D2" },
                { name: "Norris", elo: 2480, pos: 3, color: "#FF8000" },
                { name: "Alonso", elo: 2200, pos: 4, color: "#229971" },
            ]
            ex_k = EloRatingV2::BASE_K
            ex_scale = EloRatingV2::SCALE
            ex_n = ex_drivers.size
            ex_season_races = 24
            ex_k_pair = ex_k * (EloRatingV2::REFERENCE_RACES / ex_season_races.to_f) / Math.sqrt(ex_n - 1)
        %>

        <h4>Step 1: Set up the race</h4>
        <div class="elo-step-grid">
            <% ex_drivers.each do |d| %>
                <div class="elo-step-driver">
                    <span class="elo-step-pip" style="background: <%= d[:color] %>"></span>
                    <span class="elo-step-name">P<%= d[:pos] %> — <%= d[:name] %></span>
                    <span class="elo-step-rating"><%= d[:elo] %></span>
                </div>
            <% end %>
        </div>

        <h4>Step 2: Calculate K per pair</h4>
        <p>
            The K-factor for each head-to-head matchup is adjusted for season length and grid size:
        </p>
        <div class="elo-formula-block">
            <div class="elo-formula">K<sub>pair</sub> = K<sub>base</sub> × (Reference Races ÷ Season Races) ÷ √(n − 1)</div>
            <div class="elo-formula-values">= <%= ex_k %> × (<%= EloRatingV2::REFERENCE_RACES.to_i %> ÷ <%= ex_season_races %>) ÷ √(<%= ex_n %> − 1)</div>
            <div class="elo-formula-result">= <strong><%= ex_k_pair.round(2) %></strong> per matchup</div>
        </div>
        <p class="elo-note">
            Fewer season races → higher K (each race matters more). Larger grids → lower K per pair (more matchups to sum over).
        </p>

        <h4>Step 3: Head-to-head matchups</h4>
        <p>
            Every pair of drivers is compared. The higher finisher "wins" the matchup. Here are all
            <strong><%= ex_n * (ex_n - 1) / 2 %></strong> pairings:
        </p>

        <%
            # Compute all pairings
            ex_adjustments = Hash.new(0.0)
            ex_pairings = []
            ex_drivers.combination(2) do |a, b|
                ea = 1.0 / (1 + 10**((b[:elo] - a[:elo]) / ex_scale))
                eb = 1.0 - ea
                adj_a = ex_k_pair * (1.0 - ea)
                adj_b = ex_k_pair * (0.0 - eb)
                ex_adjustments[a[:name]] += adj_a
                ex_adjustments[b[:name]] += adj_b
                ex_pairings << { winner: a, loser: b, expected: ea, adj_w: adj_a, adj_l: adj_b }
            end
        %>

        <div class="elo-matchups-table-wrap">
            <table class="elo-matchups-table">
                <thead>
                    <tr>
                        <th>Matchup</th>
                        <th class="text-center">Winner</th>
                        <th class="text-center">Expected</th>
                        <th class="text-center">Surprise</th>
                        <th class="text-center">Winner Δ</th>
                        <th class="text-center">Loser Δ</th>
                    </tr>
                </thead>
                <tbody>
                    <% ex_pairings.each do |p| %>
                        <% surprise = (1.0 - p[:expected]) %>
                        <tr>
                            <td>
                                <span class="elo-step-pip" style="background: <%= p[:winner][:color] %>"></span>
                                <%= p[:winner][:name] %> <span class="text-secondary">vs</span>
                                <span class="elo-step-pip" style="background: <%= p[:loser][:color] %>"></span>
                                <%= p[:loser][:name] %>
                            </td>
                            <td class="text-center"><%= p[:winner][:name] %></td>
                            <td class="text-center mono"><%= (p[:expected] * 100).round(1) %>%</td>
                            <td class="text-center mono"><%= (surprise * 100).round(1) %>%</td>
                            <td class="text-center"><span class="text-green">+<%= p[:adj_w].round(2) %></span></td>
                            <td class="text-center"><span class="text-red"><%= p[:adj_l].round(2) %></span></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>

        <p class="elo-note">
            <strong>Expected</strong> = probability the higher-rated driver wins (based on rating gap).
            <strong>Surprise</strong> = how unexpected the result was. Beating a much stronger opponent = high surprise = big gain.
        </p>

        <h4>Step 4: Sum all adjustments</h4>
        <p>
            Each driver's total change is the sum of their gains/losses across all matchups:
        </p>

        <div class="elo-results-grid">
            <% ex_drivers.each do |d| %>
                <% adj = ex_adjustments[d[:name]] %>
                <% new_elo = d[:elo] + adj %>
                <div class="elo-result-card">
                    <div class="elo-result-header">
                        <span class="elo-step-pip" style="background: <%= d[:color] %>"></span>
                        <span class="elo-result-name"><%= d[:name] %></span>
                        <span class="elo-result-pos">P<%= d[:pos] %></span>
                    </div>
                    <div class="elo-result-body">
                        <div class="elo-result-row">
                            <span>Before</span>
                            <span class="mono"><%= d[:elo] %></span>
                        </div>
                        <div class="elo-result-row">
                            <span>Change</span>
                            <% if adj >= 0 %>
                                <span class="text-green mono">+<%= adj.round(1) %></span>
                            <% else %>
                                <span class="text-red mono"><%= adj.round(1) %></span>
                            <% end %>
                        </div>
                        <div class="elo-result-row elo-result-total">
                            <span>After</span>
                            <span class="mono"><%= new_elo.round(1) %></span>
                        </div>
                    </div>
                </div>
            <% end %>
        </div>

        <h4>Step 5: Season-end regression</h4>
        <p>
            At the end of each season, every driver's rating regresses <strong><%= (EloRatingV2::REGRESSION_FACTOR * 100).round(0) %>%</strong>
            toward the starting Elo of <%= EloRatingV2::STARTING_ELO.to_i %>. This prevents ratings from inflating forever
            and gives returning drivers a slight pull toward the mean:
        </p>
        <div class="elo-formula-block">
            <div class="elo-formula">New Elo = Current × <%= (1 - EloRatingV2::REGRESSION_FACTOR).round(2) %> + <%= EloRatingV2::STARTING_ELO.to_i %> × <%= EloRatingV2::REGRESSION_FACTOR %></div>
            <% sample = ex_drivers.first %>
            <% regressed = sample[:elo] * (1 - EloRatingV2::REGRESSION_FACTOR) + EloRatingV2::STARTING_ELO * EloRatingV2::REGRESSION_FACTOR %>
            <div class="elo-formula-values">e.g. <%= sample[:name] %>: <%= sample[:elo] %> × <%= (1 - EloRatingV2::REGRESSION_FACTOR).round(2) %> + <%= EloRatingV2::STARTING_ELO.to_i %> × <%= EloRatingV2::REGRESSION_FACTOR %> = <strong><%= regressed.round(1) %></strong> (<%= (sample[:elo] - regressed).round(1) %> toward mean)</div>
        </div>

        <h4>Key takeaways</h4>
        <ul class="elo-takeaways">
            <li><strong>Zero-sum per matchup</strong> — the winner's gain exactly equals the loser's loss</li>
            <li><strong>Upsets pay more</strong> — a low-rated driver beating a high-rated one gains big; the expected winner gains little</li>
            <li><strong>Every position matters</strong> — even P10 vs P11 creates a rating adjustment</li>
            <li><strong>Scale with the grid</strong> — with 20 drivers, each race has 190 matchups, producing meaningful Elo swings</li>
        </ul>
    </div>

    <div class="table-header" id="upset" style="margin-top: 24px;">
        <div class="table-header-title">
            <h3>When an Underdog Wins</h3>
            <a href="#upset" class="anchor-copy" data-controller="copy-anchor" data-action="click->copy-anchor#copy" title="Copy link to section"><i class="fa-solid fa-link"></i></a>
        </div>
    </div>

    <div class="card about-section elo-worked-example">
        <p class="elo-example-intro">
            Now imagine the same four drivers, but this time Alonso — rated 450 points below Verstappen — wins the race.
            Verstappen, the highest-rated driver, finishes last. This is where Elo gets interesting.
        </p>

        <%
            # Upset example: Alonso wins, Norris P2, Hamilton P3, Verstappen P4
            upset_drivers = [
                { name: "Alonso", elo: 2200, pos: 1, color: "#229971" },
                { name: "Norris", elo: 2480, pos: 2, color: "#FF8000" },
                { name: "Hamilton", elo: 2520, pos: 3, color: "#27F4D2" },
                { name: "Verstappen", elo: 2650, pos: 4, color: "#3671C6" },
            ]
            upset_k = EloRatingV2::BASE_K
            upset_scale = EloRatingV2::SCALE
            upset_n = upset_drivers.size
            upset_k_pair = upset_k * (EloRatingV2::REFERENCE_RACES / ex_season_races.to_f) / Math.sqrt(upset_n - 1)

            upset_adjustments = Hash.new(0.0)
            upset_pairings = []
            upset_drivers.combination(2) do |a, b|
                ea = 1.0 / (1 + 10**((b[:elo] - a[:elo]) / upset_scale))
                eb = 1.0 - ea
                adj_a = upset_k_pair * (1.0 - ea)
                adj_b = upset_k_pair * (0.0 - eb)
                upset_adjustments[a[:name]] += adj_a
                upset_adjustments[b[:name]] += adj_b
                upset_pairings << { winner: a, loser: b, expected: ea, adj_w: adj_a, adj_l: adj_b }
            end
        %>

        <div class="elo-step-grid">
            <% upset_drivers.each do |d| %>
                <div class="elo-step-driver">
                    <span class="elo-step-pip" style="background: <%= d[:color] %>"></span>
                    <span class="elo-step-name">P<%= d[:pos] %> — <%= d[:name] %></span>
                    <span class="elo-step-rating"><%= d[:elo] %></span>
                </div>
            <% end %>
        </div>

        <p>
            Alonso's expected win probability against Verstappen is just
            <strong><%= ((1.0 / (1 + 10**((2650 - 2200) / upset_scale))) * 100).round(1) %>%</strong>.
            By winning that matchup, the surprise factor is enormous — and the Elo reward reflects it.
            Meanwhile Verstappen, expected to beat everyone comfortably, loses all three matchups and pays a steep price.
        </p>

        <div class="elo-matchups-table-wrap">
            <table class="elo-matchups-table">
                <thead>
                    <tr>
                        <th>Matchup</th>
                        <th class="text-center">Winner</th>
                        <th class="text-center">Expected</th>
                        <th class="text-center">Surprise</th>
                        <th class="text-center">Winner Δ</th>
                        <th class="text-center">Loser Δ</th>
                    </tr>
                </thead>
                <tbody>
                    <% upset_pairings.each do |p| %>
                        <% surprise = (1.0 - p[:expected]) %>
                        <% is_big_upset = surprise > 0.6 %>
                        <tr class="<%= 'elo-highlight-gainer' if is_big_upset %>">
                            <td>
                                <span class="elo-step-pip" style="background: <%= p[:winner][:color] %>"></span>
                                <%= p[:winner][:name] %> <span class="text-secondary">vs</span>
                                <span class="elo-step-pip" style="background: <%= p[:loser][:color] %>"></span>
                                <%= p[:loser][:name] %>
                            </td>
                            <td class="text-center"><%= p[:winner][:name] %></td>
                            <td class="text-center mono"><%= (p[:expected] * 100).round(1) %>%</td>
                            <td class="text-center mono"><%= (surprise * 100).round(1) %>%</td>
                            <td class="text-center"><span class="text-green">+<%= p[:adj_w].round(2) %></span></td>
                            <td class="text-center"><span class="text-red"><%= p[:adj_l].round(2) %></span></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>

        <h4>Compare the outcomes</h4>
        <p>
            Notice how the same drivers with the same starting Elos produce dramatically different results
            depending on who finishes where. Alonso's upset win earns him nearly as much as Verstappen
            loses — the system heavily rewards beating opponents you're not expected to beat.
        </p>

        <div class="elo-results-grid">
            <% upset_drivers.each do |d| %>
                <% adj = upset_adjustments[d[:name]] %>
                <% new_elo = d[:elo] + adj %>
                <%
                    # Compare with expected result adjustments
                    expected_adj = ex_adjustments[d[:name]]
                %>
                <div class="elo-result-card">
                    <div class="elo-result-header">
                        <span class="elo-step-pip" style="background: <%= d[:color] %>"></span>
                        <span class="elo-result-name"><%= d[:name] %></span>
                        <span class="elo-result-pos">P<%= d[:pos] %></span>
                    </div>
                    <div class="elo-result-body">
                        <div class="elo-result-row">
                            <span>Before</span>
                            <span class="mono"><%= d[:elo] %></span>
                        </div>
                        <div class="elo-result-row">
                            <span>Change</span>
                            <% if adj >= 0 %>
                                <span class="text-green mono">+<%= adj.round(1) %></span>
                            <% else %>
                                <span class="text-red mono"><%= adj.round(1) %></span>
                            <% end %>
                        </div>
                        <div class="elo-result-row elo-result-total">
                            <span>After</span>
                            <span class="mono"><%= new_elo.round(1) %></span>
                        </div>
                        <div class="elo-result-row elo-result-compare">
                            <span>vs expected finish</span>
                            <% diff = adj - (expected_adj || 0) %>
                            <% if diff >= 0 %>
                                <span class="text-green mono">+<%= diff.round(1) %></span>
                            <% else %>
                                <span class="text-red mono"><%= diff.round(1) %></span>
                            <% end %>
                        </div>
                    </div>
                </div>
            <% end %>
        </div>

        <p class="elo-note">
            "vs expected finish" shows the difference compared to the first example, where everyone finished in Elo order.
            Alonso swings by <strong><%= ((upset_adjustments["Alonso"] || 0) - (ex_adjustments["Alonso"] || 0)).abs.round(1) %></strong> Elo
            compared to finishing last, while Verstappen's P4 costs him
            <strong><%= ((ex_adjustments["Verstappen"] || 0) - (upset_adjustments["Verstappen"] || 0)).abs.round(1) %></strong>
            more than his expected P1 win.
        </p>
    </div>

    <% if @example_race %>
        <div class="table-header" id="in-action">
            <div class="table-header-title">
                <h3>Elo In Action</h3>
                <a href="#in-action" class="anchor-copy" data-controller="copy-anchor" data-action="click->copy-anchor#copy" title="Copy link to section"><i class="fa-solid fa-link"></i></a>
            </div>
        </div>

        <div class="elo-race-selector">
            <span class="elo-race-selector-label">Pick a race:</span>
            <% @recent_races.each do |race| %>
                <%= link_to elo_path(race_id: race.id, anchor: "in-action"), class: "elo-race-option #{'active' if race.id == @example_race.id}" do %>
                    <%= race.circuit.name %> <%= race.season.year %>
                <% end %>
            <% end %>
        </div>

        <div class="card about-section">
            <h4><%= @example_race.circuit.name %> — <%= @example_race.season.year %> (Round <%= @example_race.round %>)</h4>
            <% if @avg_field_elo %>
                <p>Average field Elo: <strong><%= @avg_field_elo %></strong> &middot; Grid size: <strong><%= @example_results.size %></strong></p>
            <% end %>
            <% if @example_biggest_gainer %>
                <p>
                    <strong><%= @example_biggest_gainer.driver.forename[0] %>.<%= @example_biggest_gainer.driver.surname %></strong>
                    gained <span class="text-green"><strong>+<%= @example_biggest_gainer.display_elo_diff.round(1) %></strong></span>
                    by finishing P<%= @example_biggest_gainer.position_order %> against a field averaging <%= @avg_field_elo %> Elo.
                </p>
            <% end %>
            <% if @example_biggest_loser %>
                <p>
                    <strong><%= @example_biggest_loser.driver.forename[0] %>.<%= @example_biggest_loser.driver.surname %></strong>
                    dropped <span class="text-red"><strong><%= @example_biggest_loser.display_elo_diff.round(1) %></strong></span>
                    after finishing P<%= @example_biggest_loser.position_order %> — underperforming relative to their <%= @example_biggest_loser.display_old_elo&.round %> Elo.
                </p>
            <% end %>
        </div>

        <div class="card card-flush">
            <div class="table-scroll-wrapper">
                <table class="current-driver-standings compact elo-example-table">
                    <thead>
                        <tr>
                            <th class="text-center">#</th>
                            <th></th>
                            <th>Driver</th>
                            <th></th>
                            <th class="text-center">Elo Before</th>
                            <th class="text-center">Elo After</th>
                            <th class="text-center">Change</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @example_results.each do |rr| %>
                            <% is_gainer = @example_biggest_gainer && rr.id == @example_biggest_gainer.id %>
                            <% is_loser = @example_biggest_loser && rr.id == @example_biggest_loser.id %>
                            <tr class="<%= 'elo-highlight-gainer' if is_gainer %><%= 'elo-highlight-loser' if is_loser %>">
                                <td class="text-center"><%= rr.position_order %></td>
                                <td class="icon-cell">
                                    <% if rr.driver.country.present? %>
                                        <img src="https://flagsapi.com/<%= rr.driver.country.two_letter_country_code %>/shiny/24.png" alt="<%= rr.driver.country.name %>" loading="lazy" onerror="this.style.display='none'">
                                    <% end %>
                                </td>
                                <td>
                                    <%= link_to driver_path(rr.driver) do %>
                                        <%= rr.driver.forename[0] %>.<%= rr.driver.surname %>
                                    <% end %>
                                </td>
                                <td class="icon-cell">
                                    <% if rr.constructor&.logo_url.present? %>
                                        <img src="<%= rr.constructor.logo_url %>" alt="<%= rr.constructor.name %>" class="constructor-logo-sm" onerror="this.style.display='none'">
                                    <% end %>
                                </td>
                                <td class="text-center"><%= rr.display_old_elo&.round %></td>
                                <td class="text-center"><%= rr.display_new_elo&.round %></td>
                                <td class="text-center">
                                    <% if rr.display_gained_elo? %>
                                        <span class="text-green"><i class="fa-solid fa-caret-up"></i> +<%= rr.display_elo_diff.round(1) %></span>
                                    <% else %>
                                        <span class="text-red"><i class="fa-solid fa-caret-down"></i> <%= rr.display_elo_diff.round(1) %></span>
                                    <% end %>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    <% end %>
</div>
