<div class="page-hero race-day-hero">
    <div class="page-hero-bg"></div>
    <div class="page-hero-content">
        <span class="page-hero-label"><i class="fa-solid fa-circle"></i> Race Day</span>
        <h1 class="page-hero-title"><%= link_to @weekend_race.circuit.name, race_path(@weekend_race) %></h1>
        <p class="page-hero-meta">Round <%= @weekend_race.round %> · <%= @weekend_race.circuit.location %>, <%= @weekend_race.circuit.country %></p>

        <% if @next_session %>
            <div class="countdown-timer countdown-timer-race"
                 data-controller="countdown"
                 data-countdown-target-value="<%= @next_session[:starts_at].iso8601 %>"
                 data-countdown-label-value="Lights Out in">
            </div>
        <% elsif @weekend_race.starts_at %>
            <div class="race-start-time">
                <span class="race-start-label">Lights Out</span>
                <span class="race-start-value"><%= @weekend_race.starts_at.strftime("%H:%M UTC") %></span>
            </div>
        <% end %>
    </div>
</div>

<%= render "shared/circuit_kings", circuit_kings: @circuit_kings %>

<% if @session_schedule.present? %>
    <div class="card session-schedule-card">
        <%= render "pages/session_schedule", sessions: @session_schedule, race: @weekend_race %>
    </div>
<% end %>
