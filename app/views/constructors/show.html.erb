<% content_for(:title) { @constructor.name } %>
<% content_for(:description) { "#{@constructor.name} — Constructor Elo rating, season history, and driver lineups on F1 Elo." } %>
<div class="homepage-container">
    <div class="page-hero constructor-hero">
        <div class="page-hero-bg"></div>
        <div class="page-hero-content">
            <span class="page-hero-label">Constructor</span>
            <h1 class="page-hero-title">
                <% if @constructor.logo_url.present? %>
                    <img src="<%= @constructor.logo_url %>" alt="<%= @constructor.name %>" class="constructor-logo-sm constructor-logo-header">
                <% end %>
                <%= @constructor.name %>
                <% if @constructor.active %>
                    <span class="constructor-active-badge">Active</span>
                <% end %>
            </h1>
            <% if current_user && !@user_supports_any && ConstructorSupport.can_change?(current_user, current_season) %>
                <div class="constructor-hero-support">
                    <%= link_to support_constructor_path(@constructor), data: { turbo_method: :post, turbo_confirm: "Support #{@constructor.name}? This is locked until mid-season." }, class: "fantasy-btn fantasy-btn-outline" do %>
                        <i class="fa-solid fa-shield-halved"></i> Support this team
                    <% end %>
                </div>
            <% end %>
        </div>
    </div>

    <%# ── Stats Row ── %>
    <div class="race-stats-row">
        <div class="race-stat-card">
            <div class="race-stat-value"><%= @total_races %></div>
            <div class="race-stat-label">Races</div>
        </div>
        <div class="race-stat-card">
            <div class="race-stat-value"><%= @race_wins %></div>
            <div class="race-stat-label">Wins</div>
        </div>
        <div class="race-stat-card">
            <div class="race-stat-value"><%= @podiums %></div>
            <div class="race-stat-label">Podiums</div>
        </div>
        <div class="race-stat-card">
            <div class="race-stat-value"><%= @win_rate %>%</div>
            <div class="race-stat-label">Win Rate</div>
        </div>
        <% if @championship_wins > 0 %>
            <div class="race-stat-card">
                <div class="race-stat-value championship-value"><%= @championship_wins %></div>
                <div class="race-stat-label">Championships</div>
            </div>
        <% end %>
        <% if @best_season %>
            <div class="race-stat-card">
                <div class="race-stat-value"><%= @best_season[:year] %></div>
                <div class="race-stat-label">Best Season (<%= @best_season[:wins] %> wins)</div>
            </div>
        <% end %>
        <% if @supporter_count > 0 %>
            <div class="race-stat-card">
                <div class="race-stat-value"><%= @supporter_count %></div>
                <div class="race-stat-label">Supporters</div>
            </div>
        <% end %>
    </div>

    <%# ── Championship Seasons ── %>
    <% if @championship_years.any? %>
        <div class="constructor-section">
            <h4 class="constructor-section-title"><i class="fa-solid fa-trophy"></i> Championship Seasons</h4>
            <div class="constructor-championship-years">
                <% @championship_years.each do |year| %>
                    <%= link_to year, season_path(year), class: "constructor-champ-badge" %>
                <% end %>
            </div>
        </div>
    <% end %>

    <%# ── Current Lineup ── %>
    <% if @current_drivers&.any? %>
        <div class="constructor-section">
            <h4 class="constructor-section-title"><i class="fa-solid fa-users"></i> Current Lineup</h4>
            <div class="constructor-lineup-grid">
                <% @current_drivers.each do |driver| %>
                    <div class="constructor-driver-card">
                        <div class="constructor-driver-info">
                            <%= flag_image(driver, size: 24) %>
                            <%= link_to driver.fullname, driver_path(driver), class: "constructor-driver-name" %>
                            <% if driver.display_elo %>
                                <span class="constructor-driver-elo"><%= driver.display_elo.round %></span>
                            <% end %>
                        </div>
                        <% if @recent_form&.dig(driver.id)&.any? %>
                            <div class="constructor-driver-form">
                                <% @recent_form[driver.id].reverse.each do |rr| %>
                                    <% pos = rr.position_order %>
                                    <% css_class = if pos == 1 then "form-dot-gold"
                                                   elsif pos && pos <= 3 then "form-dot-podium"
                                                   elsif pos && pos <= 10 then "form-dot-points"
                                                   else "form-dot-out"
                                                   end %>
                                    <span class="form-dot <%= css_class %>" title="<%= rr.race.circuit.name %> — P<%= pos || 'DNF' %>">
                                        <%= pos || "R" %>
                                    </span>
                                <% end %>
                            </div>
                        <% end %>
                    </div>
                <% end %>
            </div>
        </div>
    <% end %>

    <%# ── Recent Results ── %>
    <% if @recent_results.any? %>
        <div class="constructor-section">
            <h4 class="constructor-section-title"><i class="fa-solid fa-flag-checkered"></i> Recent Results</h4>
            <div class="table-scroll-wrapper">
                <table class="current-driver-standings compact">
                    <thead>
                        <tr>
                            <th>Race</th>
                            <th>Driver</th>
                            <th class="text-center">Pos</th>
                            <th class="text-center">Elo +/-</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @recent_results.each do |rr| %>
                            <tr>
                                <td><%= link_to rr.race.circuit.name, race_path(rr.race) %></td>
                                <td>
                                    <span class="roster-driver-span">
                                        <%= flag_image(rr.driver, size: 24) %>
                                        <%= link_to "#{rr.driver.forename&.first}.#{rr.driver.surname}", driver_path(rr.driver) %>
                                    </span>
                                </td>
                                <td class="text-center">P<%= rr.position_order || "DNF" %></td>
                                <td class="text-center">
                                    <% diff = rr.display_elo_diff %>
                                    <span class="<%= diff >= 0 ? 'text-green' : 'text-red' %>">
                                        <%= diff >= 0 ? "+" : "" %><%= diff.round(1) %>
                                    </span>
                                </td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    <% end %>

    <%# ── Elo Over Time ── %>
    <div class="constructor-section">
        <h4 class="constructor-section-title"><i class="fa-solid fa-chart-line"></i> Elo Over Time</h4>
        <div class="constructor-chart-full">
            <%= custom_chart Graphs::Constructor.new(constructor: @constructor).data %>
        </div>
    </div>

    <%# ── Top Drivers ── %>
    <% if @top_drivers.present? %>
        <div class="constructor-section">
            <h4 class="constructor-section-title"><i class="fa-solid fa-ranking-star"></i> Top Drivers for <%= @constructor.name %></h4>
            <div class="table-scroll-wrapper">
                <table class="current-driver-standings compact" data-controller="sortable-table">
                    <thead>
                        <tr>
                            <th></th>
                            <th data-sort="text">Driver</th>
                            <th class="text-center" data-sort="num">Races</th>
                            <th class="text-center" data-sort="num">Wins</th>
                            <th class="text-center" data-sort="num">Podiums</th>
                            <th class="text-center" data-sort="num">Win %</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @top_drivers.select { |d| d[:wins] > 0 || d[:podiums] > 0 }.first(15).each_with_index do |entry, i| %>
                            <tr>
                                <td class="position-cell"><%= i + 1 %></td>
                                <td>
                                    <% driver = entry[:driver] %>
                                    <span class="roster-driver-span">
                                        <%= flag_image(driver, size: 24) %>
                                        <%= link_to driver.fullname, driver_path(driver) %>
                                    </span>
                                </td>
                                <td class="text-center"><%= entry[:races] %></td>
                                <td class="text-center"><%= entry[:wins] %></td>
                                <td class="text-center"><%= entry[:podiums] %></td>
                                <td class="text-center"><%= entry[:races] > 0 ? "#{(entry[:wins].to_f / entry[:races] * 100).round(1)}%" : "-" %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    <% end %>

    <%# ── Driver Roster History ── %>
    <% if @roster_by_season.present? %>
        <div class="constructor-section">
            <h4 class="constructor-section-title"><i class="fa-solid fa-clock-rotate-left"></i> Driver Roster History</h4>
            <div class="table-scroll-wrapper">
                <table class="current-driver-standings compact">
                    <thead>
                        <tr>
                            <th>Season</th>
                            <th>Drivers</th>
                        </tr>
                    </thead>
                    <tbody data-controller="expand">
                        <% @recent_roster.each do |season, season_drivers| %>
                            <tr>
                                <td><%= link_to season.year, season_path(season) %></td>
                                <td>
                                    <% season_drivers.map(&:driver).uniq.each do |driver| %>
                                        <span class="roster-driver-span">
                                            <%= flag_image(driver, size: 24) %>
                                            <%= link_to "#{driver.forename&.first}.#{driver.surname}", driver_path(driver) %>
                                        </span>
                                    <% end %>
                                </td>
                            </tr>
                        <% end %>
                        <% if @historical_roster.present? %>
                            <tr data-expand-target="trigger" data-action="click->expand#toggle" style="cursor: pointer;">
                                <td colspan="2" class="text-center" style="color: var(--page-accent, #e10600); font-size: 13px; font-weight: 600;">
                                    <span data-expand-target="label" data-show-text="Show <%= @historical_roster.size %> more seasons">Show <%= @historical_roster.size %> more seasons</span>
                                </td>
                            </tr>
                            <% @historical_roster.each do |season, season_drivers| %>
                                <tr data-expand-target="content" style="display: none;">
                                    <td><%= link_to season.year, season_path(season) %></td>
                                    <td>
                                        <% season_drivers.map(&:driver).uniq.each do |driver| %>
                                            <span class="roster-driver-span">
                                                <%= flag_image(driver, size: 24) %>
                                                <%= link_to "#{driver.forename&.first}.#{driver.surname}", driver_path(driver) %>
                                            </span>
                                        <% end %>
                                    </td>
                                </tr>
                            <% end %>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    <% end %>

    <%# ── Fans ── %>
    <% if @fans.any? %>
        <div class="constructor-section">
            <h4 class="constructor-section-title"><i class="fa-solid fa-heart"></i> Fans</h4>
            <div class="constructor-fans-grid">
                <% @fans.each do |fan| %>
                    <% if fan.public_profile? %>
                        <%= link_to fantasy_overview_path(fan.username), class: "constructor-fan-badge" do %>
                            <i class="fa-solid fa-user"></i>
                            <span><%= fan.display_name %></span>
                        <% end %>
                    <% else %>
                        <div class="constructor-fan-badge">
                            <i class="fa-solid fa-user"></i>
                            <span><%= fan.display_name %></span>
                        </div>
                    <% end %>
                <% end %>
            </div>
        </div>
    <% end %>
</div>
