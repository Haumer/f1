<% content_for(:title) { "Best Teammate Pairings" } %>
<% content_for(:description) { "The best F1 teammate pairings of all time, ranked by 1-2 finish rate. Minimum 5 races together." } %>
<div class="homepage-container">
    <div class="page-hero page-hero-compact">
        <div class="page-hero-bg"></div>
        <div class="page-hero-content">
            <h1 class="page-hero-title">Best Teammate Pairings</h1>
            <p class="page-hero-meta">Ranked by 1-2 finish rate. Minimum 5 races together.</p>
        </div>
    </div>

    <div class="card card-flush">
        <div class="table-scroll-wrapper">
            <table class="current-driver-standings compact" data-controller="sortable-table">
                <thead>
                    <tr>
                        <th class="text-center" data-sort="num">#</th>
                        <th></th>
                        <th data-sort="text">Driver 1</th>
                        <th></th>
                        <th data-sort="text">Driver 2</th>
                        <th></th>
                        <th class="text-center" data-sort="num">Races</th>
                        <th class="text-center" data-sort="num">Wins</th>
                        <th class="text-center" data-sort="num">Win %</th>
                        <th class="text-center" data-sort="num">1-2s</th>
                        <th class="text-center" data-sort="num">1-2 %</th>
                    </tr>
                </thead>
                <tbody>
                    <% @pairings.each_with_index do |pairing, idx| %>
                        <tr class="<%= 'podium-row podium-p' + (idx + 1).to_s if idx < 3 %>">
                            <td class="text-center position-cell"><%= idx + 1 %></td>
                            <td class="icon-cell">
                                <%= flag_image(pairing[:driver1], size: 24) %>
                            </td>
                            <td>
                                <%= link_to driver_path(pairing[:driver1]) do %>
                                    <%= pairing[:driver1].forename[0] %>.<%= pairing[:driver1].surname %>
                                <% end %>
                            </td>
                            <td class="icon-cell">
                                <%= flag_image(pairing[:driver2], size: 24) %>
                            </td>
                            <td>
                                <%= link_to driver_path(pairing[:driver2]) do %>
                                    <%= pairing[:driver2].forename[0] %>.<%= pairing[:driver2].surname %>
                                <% end %>
                            </td>
                            <td class="icon-cell">
                                <% pairing[:constructors].each do |c| %>
                                    <% if c.logo_url.present? %>
                                        <img src="<%= c.logo_url %>" alt="<%= c.name %>" class="constructor-logo-sm" title="<%= c.name %>" onerror="this.style.display='none'">
                                    <% end %>
                                <% end %>
                            </td>
                            <td class="text-center"><%= pairing[:races_together] %></td>
                            <td class="text-center"><%= pairing[:wins] %></td>
                            <td class="text-center"><%= pairing[:win_pct] %>%</td>
                            <td class="text-center"><%= pairing[:one_two_finishes] %></td>
                            <td class="text-center"><strong><%= pairing[:one_two_pct] %>%</strong></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>
</div>
