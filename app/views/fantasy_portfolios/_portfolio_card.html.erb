<% if portfolio %>
    <% stock_portfolio ||= nil %>
    <% support ||= nil %>
    <% rank ||= nil %>

    <div class="fantasy-mini-card-wrapper">
        <%= link_to fantasy_overview_path(portfolio.user.username), class: "card fantasy-mini-card" do %>
            <%# Header row: title + rank badge %>
            <div class="fantasy-mini-header">
                <div class="fantasy-mini-title">
                    <i class="fa-solid fa-chess-knight"></i>
                    <span>My Portfolio</span>
                </div>
                <% if rank %>
                    <span class="fantasy-mini-rank">
                        <i class="fa-solid fa-trophy"></i> #<%= rank %>
                    </span>
                <% end %>
            </div>

            <%# Stats row: Value, P&L, and optional team allegiance %>
            <div class="fantasy-mini-stats">
                <div class="fantasy-mini-stat">
                    <span class="label">Portfolio</span>
                    <span class="value"><%= number_with_delimiter(portfolio.portfolio_value.round(0)) %></span>
                </div>
                <div class="fantasy-mini-stat">
                    <span class="label">P&L</span>
                    <% pl = portfolio.total_return %>
                    <span class="value <%= pl >= 0 ? 'text-green' : 'text-red' %>">
                        <%= pl >= 0 ? '+' : '' %><%= number_with_delimiter(pl.round(0)) %>
                    </span>
                </div>

                <% if support&.constructor %>
                    <div class="fantasy-mini-allegiance">
                        <span class="label">Team</span>
                        <span class="fantasy-mini-team-badge">
                            <% if support.constructor.logo_url.present? %>
                                <img src="<%= support.constructor.logo_url %>" alt="" class="constructor-logo-xs" loading="lazy" onerror="this.style.display='none'">
                            <% end %>
                            <span><%= support.constructor.name %></span>
                        </span>
                    </div>
                <% end %>
            </div>

            <%# Holdings pills %>
            <% if stock_portfolio %>
                <% holdings = stock_portfolio.active_holdings.includes(:driver) %>
                <% if holdings.any? %>
                    <% sd_index = SeasonDriver.where(season: portfolio.season, driver_id: holdings.map(&:driver_id)).includes(:constructor).index_by(&:driver_id) %>
                    <div class="fantasy-mini-roster">
                        <% holdings.each do |holding| %>
                            <% constructor = sd_index[holding.driver_id]&.constructor %>
                            <% color = constructor_color(constructor) %>
                            <span class="fantasy-mini-pill" style="--pill-color: <%= color %>">
                                <% if holding.short? %><i class="fa-solid fa-arrow-trend-down" style="font-size:9px"></i><% end %>
                                <%= holding.driver.surname %>
                                <% if holding.quantity > 1 %><span style="opacity:0.6; font-size:10px"><%= holding.quantity %>x</span><% end %>
                            </span>
                        <% end %>
                    </div>
                <% end %>
            <% end %>
        <% end %>

        <%# Secondary links row (outside main link to avoid nested <a> tags) %>
        <div class="fantasy-mini-links">
            <%= link_to combined_leaderboard_path, class: "fantasy-mini-link" do %>
                <i class="fa-solid fa-ranking-star"></i> Leaderboard
            <% end %>
            <%= link_to fantasy_overview_path(portfolio.user.username), class: "fantasy-mini-link" do %>
                <i class="fa-solid fa-briefcase"></i> Portfolio
            <% end %>
        </div>
    </div>
<% end %>
