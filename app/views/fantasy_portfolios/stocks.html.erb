<% content_for(:title) { "#{@user.display_name}'s Stocks" } %>
<% content_for(:description) { "#{@user.display_name}'s fantasy F1 stock portfolio — long and short positions on driver shares." } %>
<div class="homepage-container">
    <%# Header %>
    <div class="fantasy-dashboard-header">
        <div class="fantasy-dashboard-title">
            <h2>
                <% support = ConstructorSupport.current_for(@user, @season) %>
                <% if support %>
                    <% sc = support.constructor %>
                    <% team_color = constructor_color(sc) %>
                    <span style="color: <%= team_color %>"><%= @user.display_name %></span>
                <% else %>
                    <%= @user.display_name %>
                <% end %>
            </h2>
            <span class="fantasy-season"><%= @season.year %> Stocks</span>
        </div>
        <div class="fantasy-header-actions">
            <% if @is_owner && @stock_portfolio %>
                <%= link_to market_fantasy_stock_portfolio_path(@stock_portfolio), class: "fantasy-btn fantasy-btn-primary" do %>
                    <i class="fa-solid fa-chart-line"></i> Market
                <% end %>
            <% end %>
            <%= link_to fantasy_overview_path(@user.username), class: "fantasy-btn fantasy-btn-outline" do %>
                <i class="fa-solid fa-arrow-left"></i> Overview
            <% end %>
        </div>
    </div>

    <%# Sub-Stats %>
    <% stock_pl = @stock_portfolio.profit_loss %>
    <% stock_pl_pct = @stock_portfolio.total_invested > 0 ? (stock_pl / @stock_portfolio.total_invested * 100) : 0 %>
    <div class="fantasy-sub-stats">
        <div class="fantasy-sub-stat">
            <span class="label">Value</span>
            <span class="value"><%= number_with_delimiter(@stock_portfolio.portfolio_value.round(1)) %></span>
        </div>
        <div class="fantasy-sub-stat">
            <span class="label">Credits</span>
            <span class="value"><%= number_with_delimiter(@stock_portfolio.cash.round(1)) %></span>
        </div>
        <div class="fantasy-sub-stat">
            <span class="label">Available</span>
            <span class="value"><%= number_with_delimiter(@stock_portfolio.available_cash.round(1)) %></span>
        </div>
        <div class="fantasy-sub-stat">
            <span class="label">P&L</span>
            <span class="value <%= stock_pl >= 0 ? 'text-green' : 'text-red' %>">
                <%= stock_pl >= 0 ? '+' : '' %><%= number_with_delimiter(stock_pl.round(1)) %>
                (<%= stock_pl_pct >= 0 ? '+' : '' %><%= stock_pl_pct.round(1) %>%)
            </span>
        </div>
        <div class="fantasy-sub-stat">
            <span class="label">Dividends</span>
            <span class="value text-green">+<%= number_with_delimiter(@stock_total_dividends.round(1)) %></span>
        </div>
        <div class="fantasy-sub-stat">
            <span class="label">Positions</span>
            <span class="value"><%= @stock_portfolio.position_count %>/<%= FantasyStockPortfolio::MAX_POSITIONS %></span>
        </div>
        <% if @stock_value_delta && @stock_value_delta != 0 %>
            <div class="fantasy-sub-stat">
                <span class="label">Last Race</span>
                <span class="value <%= @stock_value_delta >= 0 ? 'text-green' : 'text-red' %>">
                    <%= @stock_value_delta >= 0 ? '+' : '' %><%= @stock_value_delta.round(1) %>
                </span>
            </div>
        <% end %>
    </div>

    <% if @is_owner %>
        <%# Transfer window %>
        <% if @next_race %>
            <div class="fantasy-status-row">
                <div class="fantasy-status-item fantasy-status-<%= @stock_can_trade ? 'open' : 'closed' %>">
                    <i class="fa-solid fa-<%= @stock_can_trade ? 'lock-open' : 'lock' %>"></i>
                    <% if @stock_can_trade %>
                        <span>Window open &mdash; <%= @next_race.starts_at&.strftime("%b %d, %H:%M") || @next_race.date.strftime("%b %d") %></span>
                    <% else %>
                        <span>Window closed &mdash; <%= @next_race.circuit.name %></span>
                    <% end %>
                </div>
            </div>
        <% end %>
    <% end %>

    <%# Stock Value Chart %>
    <% if @stock_snapshots.size >= 2 %>
        <div class="table-header"><h3>Portfolio Value</h3></div>
        <div class="card card-flush fantasy-chart-card">
            <%= custom_chart({
                tooltip: { trigger: "axis" },
                grid: { left: 10, right: 20, top: 20, bottom: 10, containLabel: true },
                backgroundColor: "transparent",
                xAxis: {
                    type: "category",
                    data: @stock_snapshots.map { |s| "R#{s.race.round}" },
                    axisLabel: { color: "#666" },
                    axisLine: { lineStyle: { color: "#333" } }
                },
                yAxis: {
                    type: "value",
                    axisLabel: { color: "#666" },
                    splitLine: { lineStyle: { color: "rgba(255,255,255,0.04)" } }
                },
                series: [
                    {
                        name: "Portfolio Value",
                        type: "line",
                        data: @stock_snapshots.map { |s| s.value.round(1) },
                        smooth: true,
                        lineStyle: { color: "#e10600", width: 3 },
                        itemStyle: { color: "#e10600" },
                        areaStyle: { color: { type: "linear", x: 0, y: 0, x2: 0, y2: 1, colorStops: [{ offset: 0, color: "rgba(225,6,0,0.2)" }, { offset: 1, color: "rgba(225,6,0,0)" }] } }
                    }
                ]
            }) %>
        </div>
    <% end %>

    <%# Holdings %>
    <div class="table-header">
        <h3>Holdings</h3>
        <span class="table-header-sub"><%= @stock_holdings.size %> of <%= FantasyStockPortfolio::MAX_POSITIONS %> positions</span>
    </div>

    <% if @stock_holdings.any? %>
        <div class="card card-flush">
            <div class="table-scroll-wrapper">
                <table class="fantasy-market-table">
                    <thead>
                        <tr>
                            <th>Driver</th>
                            <th>Type</th>
                            <th class="text-end">Qty</th>
                            <th class="text-end">Entry</th>
                            <th class="text-end">Current</th>
                            <th class="text-end">P&L</th>
                            <% if @is_owner && @stock_can_trade %><th></th><% end %>
                        </tr>
                    </thead>
                    <tbody>
                        <% @stock_holdings.each do |holding| %>
                            <% constructor = @stock_constructors[holding.driver_id] %>
                            <% color = constructor_color(constructor) %>
                            <% gl = holding.gain_loss %>
                            <tr style="border-left: 3px solid <%= color %>">
                                <td>
                                    <div class="fantasy-market-driver-cell">
                                        <div class="fantasy-market-driver-info">
                                            <span class="fantasy-market-driver-name">
                                                <%= flag_image(holding.driver, size: 16) %>
                                                <%= link_to holding.driver.fullname, driver_path(holding.driver) %>
                                            </span>
                                            <span class="fantasy-market-team-name"><%= constructor&.name %></span>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <span class="stock-direction-badge stock-<%= holding.direction %>">
                                        <i class="fa-solid fa-<%= holding.long? ? 'arrow-trend-up' : 'arrow-trend-down' %>"></i>
                                        <%= holding.direction.upcase %>
                                    </span>
                                </td>
                                <td class="text-end"><span class="fantasy-market-price-cell"><%= holding.quantity %></span></td>
                                <td class="text-end"><span class="fantasy-market-price-cell"><%= holding.entry_price.round(1) %></span></td>
                                <td class="text-end"><span class="fantasy-market-price-cell"><%= holding.current_price.round(1) %></span></td>
                                <td class="text-end">
                                    <span class="<%= gl >= 0 ? 'text-green' : 'text-red' %>" style="font-weight:700; font-size:13px;">
                                        <%= gl >= 0 ? '+' : '' %><%= gl.round(1) %>
                                        <span style="font-size:11px; opacity:0.7">(<%= holding.gain_loss_percent %>%)</span>
                                    </span>
                                </td>
                                <% if @is_owner && @stock_can_trade %>
                                    <td class="text-end">
                                        <% sell_label = holding.long? ? "Sell" : "Close" %>
                                        <% sell_url = holding.long? ? sell_fantasy_stock_portfolio_path(@stock_portfolio) : short_close_fantasy_stock_portfolio_path(@stock_portfolio) %>
                                        <%= form_with url: sell_url, method: :post, local: true, class: "sell-qty-form",
                                            data: (holding.quantity > 1 ? { controller: "sell-qty", sell_qty_price_value: holding.current_price, sell_qty_max_value: holding.quantity } : {}) do %>
                                            <%= hidden_field_tag :driver_id, holding.driver_id %>
                                            <%= hidden_field_tag :quantity, holding.quantity %>
                                            <% if holding.quantity > 1 %>
                                                <div class="sell-qty-row">
                                                    <div class="stock-qty-stepper sell-qty-stepper">
                                                        <button type="button" class="stock-qty-btn" data-sell-qty-target="minus" data-action="click->sell-qty#decrement">&minus;</button>
                                                        <input type="number" min="1" max="<%= holding.quantity %>" value="<%= holding.quantity %>" class="stock-qty-input" data-sell-qty-target="input" readonly>
                                                        <button type="button" class="stock-qty-btn" data-sell-qty-target="plus" data-action="click->sell-qty#increment">+</button>
                                                    </div>
                                                    <%= submit_tag "#{sell_label} All", class: "fantasy-btn fantasy-btn-danger fantasy-btn-sm",
                                                        data: { sell_qty_target: "submit", label: sell_label, driver_name: holding.driver.fullname,
                                                                turbo_confirm: "#{sell_label} #{holding.quantity}x #{holding.driver.fullname} for #{(holding.current_price * holding.quantity).round(1)}?" } %>
                                                </div>
                                            <% else %>
                                                <%= submit_tag sell_label, class: "fantasy-btn fantasy-btn-danger fantasy-btn-sm",
                                                    data: { turbo_confirm: "#{sell_label} 1x #{holding.driver.fullname} for #{holding.current_price.round(1)}?" } %>
                                            <% end %>
                                        <% end %>
                                    </td>
                                <% end %>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    <% else %>
        <div class="card empty-state">
            <i class="fa-solid fa-chart-line"></i>
            <h3>No positions yet</h3>
            <% if @is_owner %>
                <p>You have <strong><%= number_with_delimiter(@stock_portfolio.available_cash.round(0)) %></strong> available to invest.</p>
                <%= link_to market_fantasy_stock_portfolio_path(@stock_portfolio), class: "fantasy-btn fantasy-btn-primary" do %>
                    <i class="fa-solid fa-chart-line"></i> Open your first position
                <% end %>
            <% end %>
        </div>
    <% end %>

    <%# Collateral info %>
    <% if @stock_portfolio.total_collateral > 0 %>
        <div class="fantasy-status-item fantasy-status-closed" style="margin-top: 12px; margin-bottom: 16px;">
            <i class="fa-solid fa-lock"></i>
            <span><%= number_with_delimiter(@stock_portfolio.total_collateral.round(1)) %> credits locked as collateral</span>
        </div>
    <% end %>

    <%# Transactions (owner only) %>
    <% if @is_owner %>
        <%= render "fantasy_portfolios/transactions_table", transactions: @stock_transactions, round_amount: true %>
    <% end %>

    <%# Achievements %>
    <%= render "fantasy_portfolios/achievements_grid", earned: @stock_achievements, definitions: FantasyStockAchievement::DEFINITIONS %>
</div>
