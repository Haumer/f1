<% constructor = constructors_by_driver[entry.driver.id] %>
<% color = constructor_color(constructor) %>
<% gl = entry.gain_loss %>
<% # Convert hex color to RGB for rgba() usage %>
<% color_hex = color&.gsub('#', '') || '1e1e32' %>
<% r = color_hex[0..1].to_i(16) %>
<% g = color_hex[2..3].to_i(16) %>
<% b = color_hex[4..5].to_i(16) %>
<div class="driver-card" style="--card-color: <%= color %>; --card-color-rgb: <%= r %>, <%= g %>, <%= b %>">
    <div class="driver-card-photo<%= ' driver-card-photo-empty' unless entry.driver.display_image_url.present? %>">
        <% if entry.driver.display_image_url.present? %>
            <img src="<%= entry.driver.display_image_url %>" alt="<%= entry.driver.fullname %>" loading="lazy" onerror="this.parentElement.classList.add('driver-card-photo-empty'); this.remove();">
        <% else %>
            <i class="fa-solid fa-user-helmet-safety"></i>
        <% end %>
        <span class="driver-card-pl-badge <%= gl >= 0 ? 'gain' : 'loss' %>">
            <%= gl >= 0 ? '+' : '' %><%= gl.round(0) %>
            <span style="font-size:9px; opacity:0.8">(<%= entry.gain_loss_percent %>%)</span>
        </span>
    </div>
    <div class="driver-card-body">
        <div class="driver-card-identity">
            <span class="driver-card-name"><%= link_to entry.driver.fullname, driver_path(entry.driver) %></span>
            <span class="driver-card-team"><%= constructor&.name %></span>
        </div>
        <div class="driver-card-stats">
            <div class="driver-card-stat">
                <span class="stat-label">Entry</span>
                <span class="stat-value"><%= entry.bought_at_elo.round(0) %></span>
            </div>
            <div class="driver-card-stat">
                <span class="stat-label">Now</span>
                <span class="stat-value"><%= entry.current_value.round(0) %></span>
            </div>
            <div class="driver-card-stat">
                <span class="stat-label">P&L</span>
                <span class="stat-value <%= gl >= 0 ? 'text-green' : 'text-red' %>"><%= gl >= 0 ? '+' : '' %><%= gl.round(0) %></span>
            </div>
        </div>
        <% if show_sell && can_trade && (portfolio.season.latest_race.blank? || portfolio.held_races_for(entry.driver) >= 1) %>
            <div class="driver-card-action">
                <%= form_with url: sell_fantasy_portfolio_path(portfolio), method: :post, local: true do %>
                    <%= hidden_field_tag :driver_id, entry.driver.id %>
                    <% sell_val = entry.current_value %>
                    <% fee = (sell_val * Fantasy::SellDriver::SELL_FEE) %>
                    <%= submit_tag "Sell for #{(sell_val - fee).round(0)}", class: "fantasy-btn fantasy-btn-danger fantasy-btn-sm", data: { turbo_confirm: "Sell #{entry.driver.fullname} at #{sell_val.round(0)} (#{(Fantasy::SellDriver::SELL_FEE * 100).round(0)}% fee)?" } %>
                <% end %>
            </div>
        <% end %>
    </div>
</div>
