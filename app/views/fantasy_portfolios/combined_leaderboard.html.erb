<% content_for(:title) { "Fantasy Leaderboard" } %>
<% content_for(:description) { "Fantasy F1 leaderboard — portfolio rankings for the #{@season.year} season on F1 Elo." } %>
<div class="homepage-container">
    <div class="fantasy-dashboard-header">
        <div class="fantasy-dashboard-title">
            <h2>Leaderboard</h2>
            <span class="fantasy-season"><%= @season.year %> Season</span>
        </div>
        <div class="fantasy-header-actions">
            <% if current_user %>
                <%= link_to fantasy_overview_path(current_user.username), class: "fantasy-btn fantasy-btn-outline" do %>
                    <i class="fa-solid fa-briefcase"></i> My Portfolio
                <% end %>
            <% end %>
        </div>
    </div>

    <div class="fantasy-info-banner" data-controller="dismissable" data-dismissable-key-value="fantasy-leaderboard-explainer-v2">
        <div class="fantasy-info-banner-content">
            <i class="fa-solid fa-trophy"></i>
            <p>Rankings are based on <strong>Net Value</strong> &mdash; the profit or loss you've generated from your starting capital. Everyone starts equal, so whoever generates the most value wins.</p>
        </div>
        <button class="fantasy-info-banner-close" data-action="dismissable#dismiss">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>

    <% if @entries.any? %>
        <div class="card card-flush">
            <div class="table-scroll-wrapper">
                <table class="fantasy-leaderboard-table">
                    <thead>
                        <tr>
                            <th class="text-center">#</th>
                            <th>Player</th>
                            <th class="text-end">Net Value</th>
                            <th class="text-end">Last Race</th>
                            <th class="text-end d-none d-md-table-cell">Total Value</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% @entries.each_with_index do |entry, idx| %>
                            <% portfolio = entry[:portfolio] %>
                            <% user = portfolio.user %>
                            <% is_me = current_user && user.id == current_user.id %>
                            <% support = @supports_by_user[user.id] %>
                            <% color = support ? constructor_color(support.constructor) : nil %>
                            <% last_race = @deltas[portfolio.id] || 0 %>
                            <% net = entry[:net] %>
                            <tr class="<%= 'fantasy-leaderboard-me' if is_me %> <%= "podium-p#{idx + 1}" if idx < 3 %>">
                                <td class="text-center position-cell"><%= idx + 1 %></td>
                                <td>
                                    <% if support&.constructor&.logo_url.present? %>
                                        <img src="<%= support.constructor.logo_url %>" alt="" class="constructor-logo-xs leaderboard-team-logo" onerror="this.style.display='none'">
                                    <% end %>
                                    <% if user.public_profile? %>
                                        <%= link_to fantasy_overview_path(user.username), style: color ? "color: #{color}" : nil do %><strong><%= user.display_name %></strong><% end %>
                                    <% else %>
                                        <strong <% if color %>style="color: <%= color %>"<% end %>><%= user.display_name %></strong>
                                    <% end %>
                                    <% if is_me %><span class="fantasy-you-badge">You</span><% end %>
                                </td>
                                <td class="text-end fantasy-leaderboard-value">
                                    <span class="<%= net >= 0 ? 'text-green' : 'text-red' %>">
                                        <%= net >= 0 ? '+' : '' %><%= number_with_delimiter(net.round(0)) %>
                                    </span>
                                </td>
                                <td class="text-end">
                                    <% if last_race != 0 %>
                                        <span class="<%= last_race >= 0 ? 'text-green' : 'text-red' %>">
                                            <%= last_race >= 0 ? '+' : '' %><%= number_with_delimiter(last_race.round(0)) %>
                                        </span>
                                    <% else %>
                                        <span class="text-secondary">&mdash;</span>
                                    <% end %>
                                </td>
                                <td class="text-end d-none d-md-table-cell"><%= number_with_delimiter(entry[:value].round(0)) %></td>
                            </tr>
                        <% end %>
                    </tbody>
                </table>
            </div>
        </div>
    <% else %>
        <div class="card empty-state">
            <i class="fa-solid fa-ranking-star"></i>
            <h3>No portfolios yet</h3>
            <p>Be the first to <%= link_to "create a fantasy portfolio", new_fantasy_portfolio_path %>!</p>
        </div>
    <% end %>
</div>
