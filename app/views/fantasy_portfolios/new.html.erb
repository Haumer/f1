<% content_for(:title) { "Create Fantasy Portfolio" } %>
<% content_for(:description) { "Start your Fantasy F1 portfolio — trade driver stocks, track performance, and grow your portfolio." } %>
<div class="homepage-container">
    <div class="page-hero fantasy-hero">
        <div class="page-hero-bg"></div>
        <div class="hero-glow"></div>
        <div class="page-hero-content">
            <span class="page-hero-label">Fantasy F1</span>
            <h1 class="page-hero-title">Build Your Grid</h1>
            <p class="page-hero-meta">Trade driver stocks at their Elo rating. Track performance. Grow your portfolio.</p>
        </div>
    </div>

    <div class="fantasy-onboard">
        <div class="fantasy-onboard-capital">
            <span class="fantasy-onboard-capital-label"><%= @season.year %> Season</span>
            <span class="fantasy-onboard-capital-value"><%= number_with_delimiter(@starting_capital) %></span>
            <span class="fantasy-onboard-capital-sub">Starting Capital</span>
        </div>

        <div class="fantasy-rules-grid">
            <div class="fantasy-rule-card">
                <div class="fantasy-rule-icon"><i class="fa-solid fa-chart-line"></i></div>
                <strong>Buy & Sell Shares</strong>
                <span>Go long on drivers you believe in</span>
            </div>
            <div class="fantasy-rule-card">
                <div class="fantasy-rule-icon"><i class="fa-solid fa-arrow-trend-down"></i></div>
                <strong>Short Selling</strong>
                <span>Bet against drivers you think will fall</span>
            </div>
            <div class="fantasy-rule-card">
                <div class="fantasy-rule-icon"><i class="fa-solid fa-coins"></i></div>
                <strong>Dividends</strong>
                <span>Earn dividends when your drivers finish in the top 10</span>
            </div>
            <div class="fantasy-rule-card">
                <div class="fantasy-rule-icon"><i class="fa-solid fa-chart-line"></i></div>
                <strong>Portfolio Value</strong>
                <span>Credits + current value of your positions</span>
            </div>
        </div>

        <%= form_with url: fantasy_portfolios_path, method: :post, local: true do %>
            <%= hidden_field_tag :season_id, @season.id %>
            <%= submit_tag "Start #{@season.year} Fantasy Season", class: "fantasy-btn fantasy-btn-primary fantasy-btn-lg" %>
        <% end %>
    </div>
</div>
