<div class="homepage-container"
     data-controller="fantasy-cart"
     data-fantasy-cart-cash-value="<%= @portfolio.cash %>"
     data-fantasy-cart-slots-value="<%= @portfolio.roster_slots %>"
     data-fantasy-cart-filled-value="<%= @active_driver_ids.size %>">

    <div class="fantasy-dashboard-header">
        <div class="fantasy-dashboard-title">
            <h2>Driver Market</h2>
        </div>
        <div class="fantasy-header-actions">
            <%= link_to fantasy_portfolio_path(@portfolio), class: "fantasy-btn fantasy-btn-outline" do %>
                <i class="fa-solid fa-arrow-left"></i> Portfolio
            <% end %>
        </div>
    </div>

    <div class="fantasy-transfer-status <%= @can_trade ? 'open' : 'closed' %>">
        <i class="fa-solid fa-<%= @can_trade ? 'lock-open' : 'lock' %>"></i>
        <% if @can_trade %>
            Transfer window open &mdash; closes at <%= @next_race.starts_at&.strftime("%b %d, %H:%M UTC") || @next_race.date.strftime("%b %d") %>
        <% else %>
            Transfer window closed
        <% end %>
    </div>

    <div class="fantasy-market-layout">
        <%# Driver List %>
        <div class="fantasy-market-main">
            <div class="card card-flush">
                <div class="table-scroll-wrapper">
                    <table class="fantasy-market-table">
                        <thead>
                            <tr>
                                <th>Driver</th>
                                <th>Form</th>
                                <th class="text-end">Price</th>
                                <th class="text-center" style="width:80px"></th>
                            </tr>
                        </thead>
                        <tbody>
                            <% @drivers.each do |driver| %>
                                <% on_roster = @active_driver_ids.include?(driver.id) %>
                                <% elo = Fantasy::Pricing.price_for(driver, @portfolio.season) %>
                                <% constructor = @constructors_by_driver[driver.id] %>
                                <% color = Constructor::COLORS[constructor&.constructor_ref&.to_sym] || '#6c757d' %>
                                <% trends = @elo_trends[driver.id] || [] %>
                                <tr class="fantasy-market-row <%= 'on-roster' if on_roster %>"
                                    style="--constructor-color: <%= color %>"
                                    data-fantasy-cart-target="card"
                                    data-driver-id="<%= driver.id %>"
                                    data-driver-name="<%= driver.fullname %>"
                                    data-driver-price="<%= elo %>">
                                    <td>
                                        <div class="fantasy-market-driver-cell">
                                            <span class="fantasy-market-color-pip" style="background: <%= color %>"></span>
                                            <div class="fantasy-market-driver-info">
                                                <span class="fantasy-market-driver-name">
                                                    <% if driver.country.present? %>
                                                        <img src="https://flagsapi.com/<%= driver.country.two_letter_country_code %>/shiny/16.png" alt="" loading="lazy" onerror="this.style.display='none'">
                                                    <% end %>
                                                    <%= link_to driver.fullname, driver_path(driver) %>
                                                </span>
                                                <span class="fantasy-market-team-name"><%= constructor&.name %></span>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <% if trends.any? %>
                                            <div class="fantasy-elo-trend">
                                                <div class="fantasy-elo-trend-dots">
                                                    <% trends.reverse.each do |diff| %>
                                                        <span class="fantasy-elo-dot <%= diff > 0 ? 'up' : (diff < 0 ? 'down' : 'flat') %>" title="<%= diff > 0 ? '+' : '' %><%= diff %>">
                                                            <i class="fa-solid fa-caret-<%= diff >= 0 ? 'up' : 'down' %>"></i>
                                                        </span>
                                                    <% end %>
                                                </div>
                                                <% net = trends.sum %>
                                                <span class="fantasy-elo-trend-net <%= net > 0 ? 'up' : (net < 0 ? 'down' : 'flat') %>">
                                                    <%= net > 0 ? '+' : '' %><%= net %>
                                                </span>
                                            </div>
                                        <% else %>
                                            <span class="text-tertiary" style="font-size:11px">Rookie</span>
                                        <% end %>
                                    </td>
                                    <td class="text-end">
                                        <span class="fantasy-market-price-cell"><%= elo.round(0) %></span>
                                    </td>
                                    <td class="text-center">
                                        <div class="fantasy-market-actions">
                                            <% if on_roster %>
                                                <span class="fantasy-badge-on-roster"><i class="fa-solid fa-check"></i></span>
                                            <% elsif @can_trade && !@portfolio.roster_full? %>
                                                <button type="button" class="fantasy-market-add-btn"
                                                        data-action="click->fantasy-cart#add"
                                                        title="Add to cart">
                                                    <i class="fa-solid fa-plus"></i>
                                                </button>
                                            <% end %>
                                        </div>
                                    </td>
                                </tr>
                            <% end %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <%# Sticky Cart Sidebar %>
        <div class="fantasy-market-sidebar">
            <div class="fantasy-cart-panel">
                <div class="fantasy-cart-header">
                    <div class="fantasy-cart-header-left">
                        <i class="fa-solid fa-cart-shopping"></i>
                        <strong>Cart</strong>
                        <span class="fantasy-cart-badge" data-fantasy-cart-target="cartCount">0</span>
                    </div>
                    <button class="fantasy-cart-clear" data-action="click->fantasy-cart#clear">Clear</button>
                </div>

                <%# Empty state %>
                <div class="fantasy-cart-empty" data-fantasy-cart-target="cartEmpty">
                    <i class="fa-solid fa-basket-shopping"></i>
                    <span>Add drivers to simulate pairings</span>
                    <span class="fantasy-cart-empty-meta">
                        <%= @portfolio.roster_slots - @active_driver_ids.size %> seat<%= @portfolio.roster_slots - @active_driver_ids.size == 1 ? '' : 's' %> open
                    </span>
                </div>

                <%# Filled state %>
                <div class="fantasy-cart-filled" data-fantasy-cart-target="cartItems" style="display:none">
                    <div data-fantasy-cart-target="cartList"></div>
                    <div class="fantasy-cart-summary">
                        <div class="fantasy-cart-row">
                            <span>Total</span>
                            <span class="fantasy-cart-row-value" data-fantasy-cart-target="cartTotal">0</span>
                        </div>
                        <div class="fantasy-cart-row fantasy-cart-row-remaining">
                            <span>Remaining</span>
                            <span class="fantasy-cart-row-value" data-fantasy-cart-target="cartRemaining"><%= @portfolio.cash.round(0) %></span>
                        </div>
                        <div class="fantasy-cart-row">
                            <span>Seats left</span>
                            <span class="fantasy-cart-row-value" data-fantasy-cart-target="slotsLeft"><%= @portfolio.roster_slots - @active_driver_ids.size %></span>
                        </div>
                    </div>
                    <% if @can_trade %>
                        <%= form_with url: buy_multiple_fantasy_portfolio_path(@portfolio), method: :post, local: true do %>
                            <button type="submit" class="fantasy-btn fantasy-btn-primary fantasy-cart-confirm"
                                    data-fantasy-cart-target="confirmBtn"
                                    data-action="click->fantasy-cart#confirm"
                                    disabled>
                                <i class="fa-solid fa-check"></i> Buy Drivers
                            </button>
                        <% end %>
                    <% end %>
                </div>

                <div class="fantasy-cart-cash-display">
                    <span>Cash Available</span>
                    <span class="fantasy-cart-cash-value"><%= number_with_delimiter(@portfolio.cash.round(0)) %></span>
                </div>
            </div>
        </div>
    </div>
</div>
