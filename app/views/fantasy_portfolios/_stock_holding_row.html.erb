<% constructor = stock_constructors[holding.driver_id] %>
<% color = constructor_color(constructor) %>
<% gl = holding.gain_loss %>
<% hide_sm = compact ? "d-none d-sm-table-cell" : "" %>
<% hide_md = compact ? "d-none d-md-table-cell" : "" %>
<tr style="border-left: 3px solid <%= color %>">
    <td>
        <div class="fantasy-market-driver-cell">
            <div class="fantasy-market-driver-info">
                <span class="fantasy-market-driver-name">
                    <% if holding.driver.country.present? %>
                        <%= flag_image(holding.driver, size: 16) %>
                    <% end %>
                    <%= link_to holding.driver.fullname, driver_path(holding.driver) %>
                </span>
                <span class="fantasy-market-team-name"><%= constructor&.name %></span>
            </div>
        </div>
    </td>
    <td>
        <span class="stock-direction-badge stock-<%= holding.direction %>">
            <i class="fa-solid fa-<%= holding.long? ? 'arrow-trend-up' : 'arrow-trend-down' %>"></i>
            <%= holding.direction.upcase %>
        </span>
    </td>
    <td class="text-end <%= hide_sm %>"><span class="fantasy-market-price-cell"><%= holding.quantity %></span></td>
    <td class="text-end <%= hide_md %>"><span class="fantasy-market-price-cell"><%= holding.entry_price.round(1) %></span></td>
    <td class="text-end <%= hide_md %>"><span class="fantasy-market-price-cell"><%= holding.current_price.round(1) %></span></td>
    <td class="text-end">
        <span class="<%= gl >= 0 ? 'text-green' : 'text-red' %>" style="font-weight:700; font-size:13px;">
            <%= gl >= 0 ? '+' : '' %><%= gl.round(1) %>
            <span style="font-size:11px; opacity:0.7">(<%= holding.gain_loss_percent %>%)</span>
        </span>
    </td>
    <% if show_trade_actions %>
        <td class="text-end">
            <% sell_label = holding.long? ? "Sell" : "Close" %>
            <% sell_url = holding.long? ? sell_fantasy_stock_portfolio_path(stock_portfolio) : short_close_fantasy_stock_portfolio_path(stock_portfolio) %>
            <%= form_with url: sell_url, method: :post, local: true, class: "sell-qty-form",
                data: (holding.quantity > 1 ? { controller: "sell-qty", sell_qty_price_value: holding.current_price, sell_qty_max_value: holding.quantity } : {}) do %>
                <%= hidden_field_tag :driver_id, holding.driver_id %>
                <%= hidden_field_tag :quantity, holding.quantity %>
                <% if holding.quantity > 1 %>
                    <div class="sell-qty-row">
                        <div class="stock-qty-stepper sell-qty-stepper">
                            <button type="button" class="stock-qty-btn" data-sell-qty-target="minus" data-action="click->sell-qty#decrement">&minus;</button>
                            <input type="number" min="1" max="<%= holding.quantity %>" value="<%= holding.quantity %>" class="stock-qty-input" data-sell-qty-target="input" readonly>
                            <button type="button" class="stock-qty-btn" data-sell-qty-target="plus" data-action="click->sell-qty#increment">+</button>
                        </div>
                        <%= submit_tag "#{sell_label} All", class: "fantasy-btn fantasy-btn-danger fantasy-btn-sm",
                            data: { sell_qty_target: "submit", label: sell_label, driver_name: holding.driver.fullname,
                                    turbo_confirm: "#{sell_label} #{holding.quantity}x #{holding.driver.fullname} for #{(holding.current_price * holding.quantity).round(1)}?" } %>
                    </div>
                <% else %>
                    <%= submit_tag sell_label, class: "fantasy-btn fantasy-btn-danger fantasy-btn-sm",
                        data: { turbo_confirm: "#{sell_label} 1x #{holding.driver.fullname} for #{holding.current_price.round(1)}?" } %>
                <% end %>
            <% end %>
        </td>
    <% end %>
</tr>
