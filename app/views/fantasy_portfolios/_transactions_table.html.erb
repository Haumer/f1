<% if transactions.any? %>
    <div class="table-header"><h3>Recent Transactions</h3></div>
    <div class="card card-flush">
        <div class="table-scroll-wrapper">
            <table class="fantasy-transactions-table">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th>Type</th>
                        <th>Amount</th>
                        <th class="d-none d-md-table-cell">Note</th>
                    </tr>
                </thead>
                <tbody>
                    <% transactions.each do |txn| %>
                        <tr>
                            <td><%= txn.created_at.strftime("%b %d, %H:%M") %></td>
                            <td>
                                <span class="fantasy-txn-kind fantasy-txn-<%= txn.kind %>"><%= txn.kind.humanize %></span>
                            </td>
                            <td class="<%= txn.amount >= 0 ? 'text-green' : 'text-red' %>">
                                <%= txn.amount >= 0 ? '+' : '' %><%= round_amount ? txn.amount.round(1) : txn.amount.round(0) %>
                            </td>
                            <td class="fantasy-txn-note d-none d-md-table-cell"><%= txn.note %></td>
                        </tr>
                    <% end %>
                </tbody>
            </table>
        </div>
    </div>
<% end %>
